<% content_for :title, "Hesap Oluştur" %>

<section class="page-shell grid min-h-[72vh] items-center gap-8 lg:grid-cols-[1fr_460px]">
  <div class="relative hidden overflow-hidden rounded-[1.5rem] bg-citron p-8 text-stone-950 lg:block">
    <div class="absolute inset-y-0 right-0 w-1/3 bg-white/30 blur-3xl"></div>
    <div class="relative">
      <%= render "shared/brand_mark", size: "xl", tagline: "Yeni planlar burada başlar" %>
      <h1 class="font-display mt-10 max-w-2xl text-6xl font-extrabold leading-[0.92] tracking-tight">Etkinlikleri keşfet, yerini ayır, kendi sahneni kur.</h1>
      <p class="mt-5 max-w-md text-sm font-semibold leading-6 text-stone-700">Hesap oluşturduğunda RSVP verebilir ve istediğin anda etkinlik taslağı başlatabilirsin.</p>
    </div>
  </div>

  <div class="cinema-panel rounded-[1.35rem] p-6">
    <p class="section-eyebrow text-coral">Aramıza katıl</p>
    <h1 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Hesap oluştur</h1>
    <p class="mt-2 text-sm font-medium text-stone-600">Unizone’da plan yapmaya başla.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :name, "Ad", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :email, "E-posta", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.email_field :email, autocomplete: "email", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :password, "Şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
        <% if @minimum_password_length %>
          <p class="mt-2 text-xs font-medium text-stone-500">En az <%= @minimum_password_length %> karakter.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Şifre tekrarı", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <%= f.submit "Hesap oluştur", class: "btn-electric w-full cursor-pointer border-0 focus-ring" %>
    <% end %>

    <div class="mt-5 border-t border-stone-100 pt-5 text-sm">
      <%= link_to "Zaten hesabın var mı? Giriş yap", new_user_session_path, class: "font-black text-stone-700 hover:text-coral focus-ring" %>
    </div>
  </div>
</section>
