<% content_for :title, "Yeni Şifre" %>

<section class="page-shell mx-auto max-w-md space-y-6">
  <div class="text-center">
    <div class="mb-5 inline-flex text-stone-950">
      <%= render "shared/brand_mark", size: "xl", show_wordmark: false %>
    </div>
    <p class="section-eyebrow text-coral">Hesap erişimi</p>
    <h1 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Yeni şifre belirle</h1>
  </div>

  <%= render "shared/panel" do %>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "Yeni şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Yeni şifre tekrarı", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <%= f.submit "Şifreyi değiştir", class: "btn-void w-full cursor-pointer border-0 focus-ring" %>
    <% end %>
  <% end %>
</section>
