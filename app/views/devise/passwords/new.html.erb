<% content_for :title, "Şifre Sıfırla" %>

<section class="page-shell mx-auto max-w-md space-y-6">
  <div class="text-center">
    <div class="mb-5 inline-flex text-stone-950">
      <%= render "shared/brand_mark", size: "xl", show_wordmark: false %>
    </div>
    <p class="section-eyebrow text-coral">Hesap erişimi</p>
    <h1 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Şifreni sıfırla</h1>
    <p class="mt-2 text-sm font-medium text-stone-600">E-postanı yaz, sıfırlama talimatlarını gönderelim.</p>
  </div>

  <%= render "shared/panel" do %>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-posta", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <%= f.submit "Sıfırlama talimatı gönder", class: "btn-void w-full cursor-pointer border-0 focus-ring" %>
    <% end %>

    <div class="mt-5 border-t border-stone-100 pt-5 text-sm">
      <%= link_to "Giriş sayfasına dön", new_user_session_path, class: "font-black text-stone-700 hover:text-coral focus-ring" %>
    </div>
  <% end %>
</section>
