<% content_for :title, "Giriş Yap" %>

<section class="page-shell grid min-h-[72vh] items-center gap-8 lg:grid-cols-[1fr_440px]">
  <div class="relative hidden overflow-hidden rounded-[1.5rem] bg-ink p-8 text-white lg:block">
    <div class="soft-grid absolute inset-0 opacity-35"></div>
    <div class="hero-energy absolute inset-0 opacity-70"></div>
    <div class="relative">
      <%= render "shared/brand_mark", size: "xl", tagline: "Planına geri dön" %>
      <h1 class="font-display mt-10 max-w-2xl text-6xl font-extrabold leading-[0.92] tracking-tight">Şehrin ritmi hesabında bekliyor.</h1>
      <p class="mt-5 max-w-md text-sm font-medium leading-6 text-white/68">RSVP verdiğin etkinlikleri takip et, yeni planlar keşfet ve kendi etkinliğini başlat.</p>
    </div>
  </div>

  <div class="cinema-panel rounded-[1.35rem] p-6">
    <p class="section-eyebrow text-coral">Tekrar hoş geldin</p>
    <h1 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Giriş yap</h1>
    <p class="mt-2 text-sm font-medium text-stone-600">Unizone hesabına devam et.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, "E-posta", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :password, "Şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "electric-field w-full px-4 py-3 focus:outline-none" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm font-semibold text-stone-700">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-stone-300 text-stone-950 focus:ring-citron" %>
          Beni hatırla
        </label>
      <% end %>

      <%= f.submit "Giriş yap", class: "btn-void w-full cursor-pointer border-0 focus-ring" %>
    <% end %>

    <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-stone-100 pt-5 text-sm">
      <%= link_to "Şifremi unuttum", new_password_path(resource_name), class: "font-black text-stone-700 hover:text-coral focus-ring" %>
      <%= link_to "Hesap oluştur", new_user_registration_path, class: "font-black text-stone-700 hover:text-coral focus-ring" %>
    </div>
  </div>
</section>
