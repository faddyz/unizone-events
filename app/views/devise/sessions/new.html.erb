<% content_for :title, "Giriş Yap" %>

<section class="auth-page">
  <div class="auth-shell page-shell">
    <div class="auth-workspace">
      <%= render "devise/shared/auth_showcase",
            aria_label: "Unizone keşif özeti",
            eyebrow: "Şehrin etkinlik ajansı",
            title: "Planını<br><span>şimdi</span><br>yap.",
            summary: "Konserlere, atölyelere, sergilere ve gece planlarına tek yerden dön.",
            featured_label: "En çok katılım alanlar",
            cards: [
              { title: "Kadıköy çatı konseri", meta: "7 Tem", label: "Müzik", tone: "is-citron" },
              { title: "Ürün buluşması", meta: "Yarın", label: "Teknoloji", tone: "is-blue" },
              { title: "Poster walk", meta: "3 May", label: "Sanat", tone: "is-coral" }
            ] %>

      <section class="auth-card" aria-labelledby="auth-title">
        <div class="auth-card-head">
          <p class="section-eyebrow text-coral">Hesap</p>
          <h1 id="auth-title">Tekrar hoş geldin</h1>
          <p>E-postan ve şifrenle devam et.</p>
        </div>

        <nav class="auth-switcher" aria-label="Hesap işlemleri">
          <span class="auth-switcher-item is-active" aria-current="page">Giriş</span>
          <%= link_to "Kayıt", new_user_registration_path, class: "auth-switcher-item focus-ring" %>
        </nav>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
          <div class="auth-field">
            <%= f.label :email, "E-posta", class: "auth-label" %>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  required: true,
                  class: "auth-input",
                  placeholder: "ornek@unizone.com" %>
          </div>

          <div class="auth-field">
            <div class="auth-label-row">
              <%= f.label :password, "Şifre", class: "auth-label" %>
              <%= link_to "Şifremi unuttum", new_password_path(resource_name), class: "auth-inline-link focus-ring" %>
            </div>
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  required: true,
                  class: "auth-input",
                  placeholder: "Şifren" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <label class="auth-check-row">
              <%= f.check_box :remember_me, class: "auth-checkbox" %>
              <span>Beni hatırla</span>
            </label>
          <% end %>

          <button type="submit" class="auth-submit btn-void focus-ring">
            <span>Giriş yap</span>
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </button>
        <% end %>

        <div class="auth-card-footer">
          <span>Yeni misin?</span>
          <%= link_to "Hesap oluştur", new_user_registration_path, class: "focus-ring" %>
        </div>
      </section>
    </div>
  </div>
</section>
