<%
  fallback_cards = local_assigns.fetch(:cards)
  featured_events = local_assigns.fetch(:events) { auth_featured_events(limit: 3) }.to_a
  lead_event = featured_events.first
  supporting_events = featured_events.drop(1)
%>

<aside class="auth-showcase" aria-label="<%= local_assigns.fetch(:aria_label) %>">
  <div class="auth-showcase-copy">
    <p class="section-eyebrow text-citron"><%= local_assigns.fetch(:eyebrow) %></p>
    <h2><%= local_assigns.fetch(:title).html_safe %></h2>
    <p><%= local_assigns.fetch(:summary) %></p>
  </div>

  <div class="auth-featured-block">
    <p class="auth-featured-label"><%= local_assigns.fetch(:featured_label) %></p>

    <% if lead_event %>
      <%= link_to event_path(lead_event), class: "auth-feature-hero focus-ring" do %>
        <span class="auth-feature-hero-art <%= event_poster_background_classes(lead_event) %>">
          <% if lead_event.image.attached? %>
            <%= event_image_tag lead_event,
                  :card,
                  alt: "",
                  loading: "lazy",
                  sizes: "(min-width: 1024px) 24rem, 92vw",
                  class_name: "",
                  aria: { hidden: true } %>
          <% else %>
            <span><%= lead_event.title.first.upcase %></span>
          <% end %>
        </span>
        <span class="auth-feature-hero-copy">
          <span class="auth-feature-kicker"><%= event_category_title(lead_event) %></span>
          <strong><%= lead_event.title %></strong>
          <small><%= l(lead_event.date, format: :short) %> · <%= event_going_score(lead_event) %> kişi gidiyor</small>
        </span>
      <% end %>

      <% if supporting_events.any? %>
        <div class="auth-featured-list">
          <% supporting_events.each do |event| %>
            <%= link_to event_path(event), class: "auth-feature-card focus-ring" do %>
              <span class="auth-feature-dot" aria-hidden="true"></span>
              <span class="auth-feature-copy">
                <strong><%= event.title %></strong>
                <small><%= event_category_title(event) %> · <%= event_going_score(event) %> kişi</small>
              </span>
              <span class="auth-feature-pill"><%= l(event.date, format: :short) %></span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="auth-featured-list">
        <% fallback_cards.each do |card| %>
          <div class="auth-feature-card <%= card.fetch(:tone) %>">
            <span class="auth-feature-dot" aria-hidden="true"></span>
            <span class="auth-feature-copy">
              <strong><%= card.fetch(:title) %></strong>
              <small><%= card.fetch(:meta) %></small>
            </span>
            <span class="auth-feature-pill"><%= card.fetch(:label) %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</aside>
