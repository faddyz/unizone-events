<% explore_active = current_page?(explore_events_path) || (controller_path == "events" && action_name.in?(%w[explore show])) %>
<% dashboard_active = controller_path == "dashboards" %>
<% organizer_active = controller_path.start_with?("organizer/") %>
<% admin_active = controller_path.start_with?("admin/") %>
<% account_active = controller_path.start_with?("account/") %>
<% auth_active = controller_path.start_with?("devise/") %>

<nav class="uz-nav fixed inset-x-0 top-0 z-50"
     data-controller="navbar"
     data-transparent="<%= content_for?(:transparent_nav) ? "true" : "false" %>"
     data-scrolled="false">
  <div class="uz-nav-inner flex items-center gap-4 py-3 lg:py-3.5">
    <%= link_to root_path, class: "nav-brand group inline-flex min-w-0 items-center gap-3 focus-ring", aria: { label: "Unizone ana sayfa" } do %>
      <%= render "shared/brand_mark", size: "nav", tagline: nil %>
    <% end %>

    <div class="hidden flex-1 items-center lg:flex">
      <div class="nav-link-cluster">
        <%= link_to explore_events_path,
              class: "nav-link focus-ring #{explore_active ? "is-active" : ""}",
              aria: (explore_active ? { current: "page" } : {}) do %>
          <span>Keşfet</span>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to dashboard_path,
                class: "nav-link focus-ring #{dashboard_active ? "is-active" : ""}",
                aria: (dashboard_active ? { current: "page" } : {}) do %>
            <span>Planlarım</span>
          <% end %>

          <%= link_to organizer_events_path,
                class: "nav-link focus-ring #{organizer_active ? "is-active" : ""}",
                aria: (organizer_active ? { current: "page" } : {}) do %>
            <span>Etkinliklerim</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="ml-auto hidden items-center gap-2.5 lg:flex">
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= link_to admin_events_path,
                class: "nav-review-link focus-ring #{admin_active ? "is-active" : ""}",
                aria: (admin_active ? { current: "page" } : {}) do %>
            <span class="nav-review-dot"></span>
            <span>İnceleme</span>
          <% end %>
        <% end %>

        <%= link_to new_organizer_event_path, class: "nav-create-link focus-ring #{current_page?(new_organizer_event_path) ? "is-active" : ""}" do %>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          <span>Etkinlik Oluştur</span>
        <% end %>

        <details class="nav-account-menu" data-controller="account-menu">
          <summary class="nav-account-trigger focus-ring <%= account_active ? "is-active" : "" %>" data-action="keydown->account-menu#keydown">
            <span class="nav-account-avatar"><%= (current_user.name.presence || current_user.email).first.upcase %></span>
            <span class="nav-account-copy">
              <span class="nav-account-name"><%= current_user.name.presence || "Hesap" %></span>
              <span class="nav-account-meta">Profil ve ayarlar</span>
            </span>
            <svg class="nav-account-chevron size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="nav-account-panel">
            <div class="nav-account-panel-head">
              <span class="nav-account-avatar is-large"><%= (current_user.name.presence || current_user.email).first.upcase %></span>
              <span class="min-w-0">
                <span class="block truncate text-sm font-black text-stone-950"><%= current_user.name.presence || "Unizone hesabı" %></span>
                <span class="block truncate text-xs font-bold text-stone-500"><%= current_user.email %></span>
              </span>
            </div>

            <%= link_to account_profile_path, class: "nav-account-item focus-ring #{account_active ? "is-active" : ""}" do %>
              <%= render "icons/users", class: "size-4" %>
              <span>Profil</span>
            <% end %>
            <%= link_to dashboard_path, class: "nav-account-item focus-ring #{dashboard_active ? "is-active" : ""}" do %>
              <%= render "icons/calendar", class: "size-4" %>
              <span>Planlarım</span>
            <% end %>
            <%= link_to organizer_events_path, class: "nav-account-item focus-ring #{organizer_active ? "is-active" : ""}" do %>
              <%= render "icons/ticket", class: "size-4" %>
              <span>Etkinliklerim</span>
            <% end %>
            <%= button_to destroy_user_session_path, method: :delete, class: "nav-account-item nav-account-danger w-full text-left focus-ring" do %>
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                <path d="M16 17l5-5-5-5M21 12H9"/>
                <path d="M13 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8"/>
              </svg>
              <span>Çıkış</span>
            <% end %>
          </div>
        </details>
      <% else %>
        <%= link_to "Giriş", new_user_session_path, class: "nav-login-link focus-ring #{auth_active ? "is-active" : ""}" %>
        <%= link_to "Ücretsiz Katıl", new_user_registration_path, class: "nav-join-link focus-ring #{current_page?(new_user_registration_path) ? "is-active" : ""}" %>
      <% end %>
    </div>

    <div class="ml-auto lg:hidden">
      <% if user_signed_in? %>
        <button type="button"
                class="mobile-account-avatar focus-ring"
                aria-label="Hesap Menüsünü Aç"
                aria-controls="mobile-account-sheet"
                aria-expanded="false"
                data-account-menu-target="mobileTrigger"
                data-action="account-menu#openMobile">
          <%= (current_user.name.presence || current_user.email).first.upcase %>
        </button>
      <% else %>
        <%= link_to "Giriş", new_user_session_path, class: "btn-void min-h-10 px-4 py-2 text-sm focus-ring" %>
      <% end %>
    </div>
  </div>
</nav>
