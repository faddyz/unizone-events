<footer class="site-footer mt-16 border-t border-white/10 bg-void pb-20 text-white lg:pb-0">
  <div class="page-shell footer-shell py-14 lg:py-16">
    <div class="footer-brand-block">
      <%= render "shared/brand_mark", size: "md", tagline: "Şehrin etkinlik ajandası" %>
      <p class="mt-5 max-w-sm text-sm font-medium leading-6 text-white/62">
        Konserlerden atölyelere, sergilerden gece planlarına kadar şehirde gerçekten gitmek isteyeceğin etkinlikleri tek yerde toplar.
      </p>

      <div class="footer-socials" aria-label="Sosyal medya">
        <a href="#" class="footer-social-link focus-ring" aria-label="Instagram">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="4" y="4" width="16" height="16" rx="5"/>
            <circle cx="12" cy="12" r="3.5"/>
            <path d="M17.5 6.5h.01"/>
          </svg>
        </a>
        <a href="#" class="footer-social-link focus-ring" aria-label="X">
          <%= render "icons/twitter", class: "size-4" %>
        </a>
        <a href="#" class="footer-social-link focus-ring" aria-label="Facebook">
          <%= render "icons/facebook", class: "size-4" %>
        </a>
        <a href="#" class="footer-social-link focus-ring" aria-label="LinkedIn">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.5 8.8H3.8V20h2.7V8.8ZM5.2 4a1.55 1.55 0 1 0 0 3.1 1.55 1.55 0 0 0 0-3.1ZM20.2 13.5c0-3-1.6-4.9-4.1-4.9-1.7 0-2.7.9-3.1 1.7V8.8h-2.7V20H13v-5.8c0-1.7.8-2.8 2.2-2.8 1.3 0 2.1.9 2.1 2.7V20h2.8v-6.5Z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-map">
      <div>
        <h3 class="footer-heading">Keşfet</h3>
        <div class="mt-4 grid gap-1.5">
          <%= link_to "Tüm etkinlikler", explore_events_path, class: "footer-link focus-ring" %>
          <%= link_to "Yaklaşan planlar", explore_events_path(date_filter: "upcoming"), class: "footer-link focus-ring" %>
          <%= link_to "Popüler etkinlikler", explore_events_path(sort_by: "popular"), class: "footer-link focus-ring" %>
          <%= link_to "Kategori rehberi", explore_events_path, class: "footer-link focus-ring" %>
        </div>
      </div>

      <div>
        <h3 class="footer-heading">Organizatör</h3>
        <div class="mt-4 grid gap-1.5">
          <%= link_to "Etkinlik oluştur", new_organizer_event_path, class: "footer-link focus-ring" %>
          <% if user_signed_in? %>
            <%= link_to "Etkinliklerim", organizer_events_path, class: "footer-link focus-ring" %>
            <%= link_to "Planlarım", dashboard_path, class: "footer-link focus-ring" %>
            <% if current_user.admin? %>
              <%= link_to "İnceleme paneli", admin_events_path, class: "footer-link focus-ring" %>
            <% end %>
          <% else %>
            <%= link_to "Giriş yap", new_user_session_path, class: "footer-link focus-ring" %>
            <%= link_to "Hesap oluştur", new_user_registration_path, class: "footer-link focus-ring" %>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="footer-heading">Unizone</h3>
        <div class="mt-4 grid gap-1.5">
          <%= link_to "SSS", faq_path, class: "footer-link focus-ring" %>
          <%= link_to "Gizlilik", faq_path(anchor: "gizlilik"), class: "footer-link focus-ring" %>
          <%= link_to "Topluluk kuralları", faq_path(anchor: "topluluk"), class: "footer-link focus-ring" %>
          <%= link_to "İletişim", "#", class: "footer-link focus-ring" %>
        </div>
      </div>
    </div>

    <aside class="newsletter-shell">
      <p class="section-eyebrow text-citron">Bülten</p>
      <h3 class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight">Haftanın iyi planları yakında kutunda.</h3>
      <p class="mt-3 text-sm font-medium leading-6 text-white/55">
        Şehirde konuşulan etkinlikleri, yeni kategorileri ve organizatör duyurularını tek özetle al.
      </p>

      <div class="mt-5 flex gap-2">
        <input type="email" disabled placeholder="mail@ornek.com" class="footer-newsletter-input min-w-0 flex-1">
        <button type="button" disabled class="footer-newsletter-button">Yakında</button>
      </div>
    </aside>
  </div>

  <div class="page-shell footer-bottom">
    <span>© <%= Time.current.year %> Unizone</span>
    <span>Electric City arayüzü ile şehir planları için tasarlandı.</span>
  </div>
</footer>
