<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= favicon_link_tag "favicon.svg", type: "image/svg+xml" %>
    <title><%= content_for(:title) || "Unizone | Şehrin Ritmini Keşfet" %></title>
    <meta name="description" content="Unizone ile şehrindeki konserleri, partileri, atölyeleri ve özel buluşmaları keşfet. Moduna uygun planı bul, arkadaşlarınla katıl ve şehrin akışına dahil ol.">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preload" href="<%= asset_path("unizone/syne-latin.woff2") %>" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path("unizone/syne-latin-ext.woff2") %>" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path("unizone/bricolage-latin.woff2") %>" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path("unizone/bricolage-latin-ext.woff2") %>" as="font" type="font/woff2" crossorigin>
    <%= render "layouts/font_faces" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag(
          "base/tokens",
          "base/global",
          "components/brand",
          "components/navigation",
          "components/surfaces",
          "components/forms",
          "components/buttons",
          "components/footer",
          "components/shared",
          "base/animations",
          "data-turbo-track": "reload"
        ) %>
    <%= yield :stylesheets %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen text-stone-950 antialiased" data-controller="account-menu">
    <%= link_to "İçeriğe geç", "#main-content", class: "sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[70] focus:rounded-md focus:bg-stone-950 focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-white" %>
    <%= render "layouts/navbar" %>

    <main id="main-content" class="min-h-[calc(100vh-8rem)] pb-24 lg:pb-0 <%= content_for?(:transparent_nav) ? "" : "pt-24" %>">
      <div class="page-shell">
        <% flash.each do |key, value| %>
          <div role="status" class="mb-6 rounded-2xl border px-4 py-3 text-sm font-bold shadow-sm <%= key.to_s == "alert" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-emerald-200 bg-emerald-50 text-emerald-800" %>">
            <%= value %>
          </div>
        <% end %>
      </div>

      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
    <%= render "layouts/bottom_nav" %>
  </body>
</html>
