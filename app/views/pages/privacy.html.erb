<% content_for :title, "Gizlilik Politikası ve KVKK Aydınlatma Metni" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/static-pages") %>

<% privacy_nav = [
  ["Veri sorumlusu", "#privacy-veri-sorumlusu"],
  ["İşlenen veriler", "#privacy-islenen-veriler"],
  ["İşleme amaçları", "#privacy-amaclar"],
  ["Veri aktarımı", "#privacy-aktarim"],
  ["Çerezler", "#privacy-cerezler"],
  ["KVKK hakları", "#privacy-haklar"],
  ["İletişim", "#privacy-iletisim"]
] %>

<main class="static-page legal-page">
  <div class="page-shell static-page-shell">
    <header class="static-hero">
      <p class="section-eyebrow text-coral">Gizlilik</p>
      <h1 class="mt-3">Gizlilik Politikası ve KVKK Aydınlatma Metni</h1>
      <p class="mt-4">
        Unizone’da hangi kişisel verilerin işlendiğini, hangi amaçlarla kullanıldığını, hangi taraflarla paylaşılabileceğini ve KVKK kapsamındaki haklarını burada bulabilirsin.
      </p>
      <div class="static-hero-actions">
        <%= link_to "Kullanım koşulları", terms_path, class: "static-pill-link is-primary focus-ring" %>
        <%= link_to "İletişime geç", contact_path, class: "static-pill-link focus-ring" %>
      </div>
    </header>

    <div class="static-layout">
      <aside class="static-side-card is-dark" aria-label="Gizlilik başlıkları">
        <p class="section-eyebrow text-citron">Başlıklar</p>
        <nav class="static-nav-list mt-4">
          <% privacy_nav.each do |label, href| %>
            <a href="<%= href %>" class="focus-ring"><%= label %></a>
          <% end %>
        </nav>
      </aside>

      <div class="static-content-stack">
        <section class="static-content-card legal-content-card">
          <%= render "pages/privacy_content" %>
        </section>
      </div>
    </div>
  </div>
</main>
