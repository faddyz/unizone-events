<% content_for :title, "SSS" %>

<% faq_groups = [
  {
    id: "kesif",
    title: "Etkinlik keşfi",
    intro: "Unizone, şehirdeki etkinlikleri daha hızlı taraman ve sana uyan planları kaybetmemen için tasarlandı.",
    items: [
      ["Unizone'da nasıl etkinlik bulurum?", "Ana sayfadaki arama alanını veya Keşfet sayfasındaki kategori, tarih ve sıralama filtrelerini kullanabilirsin. Etkinlik kartları tarih, konum, kategori ve katılım sinyallerini öne çıkarır."],
      ["Etkinlik detayında hangi bilgileri görürüm?", "Etkinlik sayfasında açıklama, tarih-saat, konum, kategori, organizatör bilgisi, bilet bağlantısı varsa yönlendirme ve katılım seçenekleri yer alır."],
      ["Planlarımı nereden takip ederim?", "Giriş yaptıktan sonra Planlarım alanında ilgilendiğin veya katılacağını belirttiğin etkinlikleri görebilirsin."]
    ]
  },
  {
    id: "hesap",
    title: "Hesap ve katılım",
    intro: "Hesap, planlarını kaydetmek ve etkinlik oluşturmak için kullanılır.",
    items: [
      ["Hesap açmadan etkinlikleri görebilir miyim?", "Evet. Etkinlikleri gezebilir ve detay sayfalarını inceleyebilirsin. Katılım durumu seçmek, planlarını saklamak ve etkinlik oluşturmak için giriş yapman gerekir."],
      ["RSVP seçenekleri ne anlama geliyor?", "Gidiyorum, ilgileniyorum veya gitmiyorum seçenekleri etkinlikle ilişkini kaydetmeni sağlar. Bu bilgi planlarını düzenlemek ve etkinlik ilgisini göstermek için kullanılır."],
      ["Profil bilgilerimi değiştirebilir miyim?", "Evet. Hesap alanından adını, e-posta adresini ve şifreni güncelleyebilirsin."]
    ]
  },
  {
    id: "organize",
    title: "Etkinlik oluşturma",
    intro: "Organizatör akışı, etkinliği taslaktan yayına hazırlamak için adım adım ilerler.",
    items: [
      ["Nasıl etkinlik oluştururum?", "Etkinlik Oluştur sayfasından temel bilgileri, tarih-saat detaylarını, konumu, açıklamayı ve görseli ekleyerek taslak oluşturabilirsin."],
      ["Etkinlik neden incelemeye gider?", "Unizone, keşif deneyimini güvenilir tutmak için yeni veya önemli ölçüde değişen etkinlikleri kısa bir kalite kontrolünden geçirir."],
      ["Yayındaki etkinliği düzenleyebilir miyim?", "Evet. Yayındaki etkinlikleri düzenleyebilirsin. Kritik değişiklikler tekrar inceleme gerektirebilir."]
    ]
  },
  {
    id: "bilet",
    title: "Biletler ve destek",
    intro: "Unizone etkinlik keşfine odaklanır; bilet satışı veya ödeme akışı varsa genellikle organizatörün bağlantısına yönlendirir.",
    items: [
      ["Unizone bilet satıyor mu?", "Bu sürümde Unizone doğrudan bilet satışı yapmaz. Etkinlikte bilet bağlantısı varsa seni organizatörün veya ilgili üçüncü taraf platformun sayfasına yönlendirir."],
      ["Üçüncü taraf bilet linklerinde sorumluluk kimde?", "Bilet satın alma, iade, ücret ve giriş koşulları ilgili organizatörün veya bilet platformunun kurallarına tabidir."],
      ["Destek için nasıl ulaşırım?", "İletişim sayfasındaki destek adresinden etkinlik, hesap, gizlilik veya geri bildirim konularında bize yazabilirsin."]
    ]
  }
] %>

<main class="static-page">
  <div class="page-shell static-page-shell">
    <header class="static-hero">
      <p class="section-eyebrow text-coral">Yardım merkezi</p>
      <h1 class="mt-3">Sık sorulan sorular</h1>
      <p class="mt-4">
        Unizone'da etkinlik keşfetme, plan kaydetme, etkinlik oluşturma ve destek alma konusunda en sık sorulan yanıtları burada topladık.
      </p>
      <div class="static-hero-actions">
        <%= link_to "İletişime geç", contact_path, class: "static-pill-link is-primary focus-ring" %>
        <%= link_to "Gizlilik politikası", privacy_policy_path, class: "static-pill-link focus-ring" %>
      </div>
    </header>

    <div class="static-layout">
      <aside class="static-side-card" aria-label="SSS başlıkları">
        <p class="section-eyebrow text-coral">Konular</p>
        <nav class="static-nav-list mt-3">
          <% faq_groups.each do |group| %>
            <a href="#<%= group[:id] %>" class="focus-ring"><%= group[:title] %></a>
          <% end %>
        </nav>
      </aside>

      <div class="static-content-stack">
        <% faq_groups.each do |group| %>
          <section id="<%= group[:id] %>" class="static-content-card">
            <header>
              <p class="section-eyebrow text-coral">SSS</p>
              <h2 class="mt-2"><%= group[:title] %></h2>
              <p class="mt-3"><%= group[:intro] %></p>
            </header>

            <div class="static-faq-grid pt-0">
              <% group[:items].each do |question, answer| %>
                <details class="static-faq-item">
                  <summary><%= question %></summary>
                  <p><%= answer %></p>
                </details>
              <% end %>
            </div>
          </section>
        <% end %>

        <section id="topluluk" class="static-content-card">
          <header>
            <p class="section-eyebrow text-coral">Topluluk</p>
            <h2 class="mt-2">Güvenli ve kullanışlı bir etkinlik akışı</h2>
            <p class="mt-3">
              Etkinliklerin doğru, güncel ve katılımcılar için anlaşılır olmasını bekleriz. Yanıltıcı başlıklar, eksik konum bilgisi veya güvenli olmayan içerikler yayına alınmayabilir.
            </p>
          </header>
        </section>
      </div>
    </div>
  </div>
</main>
