<% content_for :title, "Yardım" %>

<% faq_items = [
  ["Nasıl etkinlik oluştururum?", "Etkinlik Oluştur sayfasından taslak başlat, temel detayları ekle ve hazır olduğunda incelemeye gönder."],
  ["Etkinlik ne zaman yayına çıkar?", "Etkinlikler kısa bir kalite incelemesinden sonra yayına alınır; böylece takvim güvenilir ve kullanışlı kalır."],
  ["Yayındaki etkinliği düzenleyebilir miyim?", "Evet. Önemli değişiklikler yeniden incelenir ve ardından herkese görünür hale gelir."],
  ["RSVP nasıl çalışır?", "Giriş yapan kullanıcılar etkinlik için gidiyorum, ilgileniyorum veya gitmiyorum seçebilir."],
  ["Etkinlik iptal edilebilir mi?", "Evet. İptal edilen etkinlikler keşiften kaldırılır; geçmişi etkinliği oluşturan kullanıcı için korunur."]
] %>

<section class="page-shell mx-auto max-w-3xl space-y-6">
  <%= render "shared/page_header", eyebrow: "Yardım", title: "Sık sorulan sorular" %>

  <div class="space-y-3" data-controller="accordion">
    <% faq_items.each_with_index do |(question, answer), index| %>
      <% item_index = index + 1 %>
      <section class="cinema-panel rounded-[1.5rem]">
        <button type="button"
                class="flex w-full items-center justify-between gap-4 px-4 py-4 text-left focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-400"
                data-action="accordion#toggle"
                data-accordion-target="button"
                data-accordion-index="<%= item_index %>"
                aria-expanded="false"
                aria-controls="faq-panel-<%= item_index %>"
                data-accordion-index-param="<%= item_index %>">
          <span class="font-black text-stone-950"><%= question %></span>
          <span class="text-lg leading-none text-stone-400" data-accordion-target="icon" data-accordion-index="<%= item_index %>" aria-hidden="true">+</span>
        </button>
        <div id="faq-panel-<%= item_index %>"
             class="hidden px-4 pb-4 text-sm font-semibold leading-6 text-stone-600"
             data-accordion-target="panel"
             data-accordion-index="<%= item_index %>">
          <%= answer %>
        </div>
      </section>
    <% end %>
  </div>
</section>
