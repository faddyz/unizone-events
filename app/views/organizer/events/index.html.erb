<% content_for :title, "Etkinliklerim" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/member-workbench") %>

<% active_filters = @query.present? || @selected_status != "all" %>
<% status_counts = @stats.transform_keys(&:to_s) %>

<section class="member-workbench organizer-workbench page-shell">
  <header class="workbench-hero organizer-hero">
    <div class="soft-grid absolute inset-0 opacity-35"></div>
    <div class="workbench-hero-copy">
      <p class="section-eyebrow text-citron">Etkinliklerim</p>
      <h1>Planlarını taslaktan yayına taşı.</h1>
      <p>Fikirlerini düzenle, inceleme durumunu takip et ve yayındayken RSVP hareketini net bir iş masasında gör.</p>

      <div class="workbench-hero-actions">
        <%= link_to new_organizer_event_path, class: "workbench-primary-action focus-ring" do %>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          <span>Etkinlik oluştur</span>
        <% end %>
        <%= link_to dashboard_path, class: "workbench-secondary-action focus-ring" do %>
          <%= render "icons/calendar", class: "size-4" %>
          <span>Planlarıma dön</span>
        <% end %>
      </div>
    </div>

    <aside class="organizer-hero-status">
      <p class="section-eyebrow text-white/42">Durum nabzı</p>
      <div class="organizer-hero-status-grid">
        <div>
          <strong><%= @stats[:draft] %></strong>
          <span>Taslak</span>
        </div>
        <div>
          <strong><%= @stats[:submitted] %></strong>
          <span>İncelemede</span>
        </div>
        <div>
          <strong><%= @stats[:published] %></strong>
          <span>Yayında</span>
        </div>
      </div>
      <p class="organizer-hero-note">Hazır olmayan fikirleri taslakta tut, hazır olanları tek hamlede incelemeye gönder.</p>
    </aside>
  </header>

  <div class="workbench-signal-grid">
    <% [
      [ "Toplam", @stats[:total], "Tüm etkinliklerin" ],
      [ "Taslak", @stats[:draft], "Düzenleme bekleyenler" ],
      [ "İncelemede", @stats[:submitted], "Onay kuyruğunda" ],
      [ "Yayında", @stats[:published], "Keşifte görünenler" ]
    ].each_with_index do |(label, value, hint), index| %>
      <article class="workbench-signal-card is-tone-<%= index + 1 %>">
        <span class="workbench-signal-dot"></span>
        <p><%= label %></p>
        <strong><%= value %></strong>
        <small><%= hint %></small>
      </article>
    <% end %>
  </div>

  <section class="organizer-controls">
    <div class="organizer-status-tabs" aria-label="Etkinlik durumu">
      <% @status_tabs.each do |key, label| %>
        <%= link_to organizer_events_path(status: (key == "all" ? nil : key), query: @query.presence),
              class: "organizer-status-tab #{key == @selected_status ? "is-active" : ""} focus-ring",
              aria: (key == @selected_status ? { current: "page" } : {}) do %>
          <span><%= label %></span>
          <strong><%= key == "all" ? @stats[:total] : status_counts.fetch(key, 0) %></strong>
        <% end %>
      <% end %>
    </div>

    <%= form_with url: organizer_events_path, method: :get, class: "organizer-search-form", local: true do %>
      <% unless @selected_status == "all" %>
        <%= hidden_field_tag :status, @selected_status %>
      <% end %>
      <label class="sr-only" for="organizer-event-query">Etkinlik ara</label>
      <div class="organizer-search-field">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <%= text_field_tag :query, @query, id: "organizer-event-query", placeholder: "Başlık, şehir veya mekan ara", class: "focus-ring" %>
      </div>
      <%= submit_tag "Ara", class: "organizer-search-submit focus-ring" %>
      <% if active_filters %>
        <%= link_to "Temizle", organizer_events_path, class: "organizer-clear-link focus-ring" %>
      <% end %>
    <% end %>
  </section>

  <section class="organizer-results">
    <div class="workbench-section-head">
      <div>
        <p class="section-eyebrow text-coral">Workbench</p>
        <h2><%= @events.size %> etkinlik gösteriliyor</h2>
      </div>
      <span class="organizer-results-meta">
        <%= @selected_status == "all" ? "Tüm durumlar" : @status_tabs.to_h.fetch(@selected_status) %>
      </span>
    </div>

    <% if @events.any? %>
      <div class="organizer-event-grid">
        <% @events.each do |event| %>
          <article class="organizer-event-card">
            <div class="organizer-event-poster <%= event_poster_background_classes(event) %>">
              <% if event.image.attached? %>
                <%= event_image_tag event,
                      :thumb,
                      alt: event.title,
                      loading: "lazy",
                      sizes: "5rem",
                      class_name: "" %>
                <div class="organizer-event-poster-shade"></div>
              <% else %>
                <div class="poster-noise absolute inset-0"></div>
              <% end %>
              <div class="organizer-date-ticket">
                <span><%= event.date.strftime("%b") %></span>
                <strong><%= event.date.strftime("%-d") %></strong>
              </div>
            </div>

            <div class="organizer-event-body">
              <div class="organizer-event-tags">
                <span class="<%= event_status_badge_classes(event) %>"><%= event_status_label(event) %></span>
                <span class="<%= event_category_badge_classes(event) %>"><%= event_category_title(event) %></span>
              </div>

              <h3><%= link_to event.title, organizer_event_path(event), class: "focus-ring" %></h3>
              <p><%= event_lifecycle_hint(event) %></p>

              <% if event.rejected? && event.review_note.present? %>
                <div class="organizer-review-note">
                  <span>İnceleme notu</span>
                  <p><%= event.review_note %></p>
                </div>
              <% end %>

              <dl class="organizer-event-facts">
                <div>
                  <dt>Tarih</dt>
                  <dd><%= l(event.date, format: :short) %></dd>
                </div>
                <div>
                  <dt>Şehir</dt>
                  <dd><%= event.city %></dd>
                </div>
                <div>
                  <dt>RSVP</dt>
                  <dd><%= event.total_responses_count %></dd>
                </div>
                <div>
                  <dt>Kontenjan</dt>
                  <dd><%= event.capacity.presence || "Açık" %></dd>
                </div>
              </dl>

              <div class="organizer-event-actions">
                <%= link_to "Aç", organizer_event_path(event), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                <%= link_to "Düzenle", edit_organizer_event_path(event), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                <% if event.published? %>
                  <%= link_to "Yayındaki sayfa", event_path(event), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                <% else %>
                  <%= link_to "Önizle", event_path(event), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                <% end %>
                <% unless event.submitted? || event.cancelled? %>
                  <%= button_to "İncelemeye gönder", submit_organizer_event_path(event), method: :patch, class: "btn-electric min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="workbench-empty-state organizer-empty">
        <span class="dashboard-empty-dot"></span>
        <h3><%= active_filters ? "Bu filtrelerle etkinlik yok" : "Henüz etkinlik oluşturmadın" %></h3>
        <p><%= active_filters ? "Aramayı temizleyerek tüm etkinliklerine dönebilir veya yeni bir fikir başlatabilirsin." : "Bir taslakla başla ve fikrini kendi hızında şekillendir." %></p>
        <div class="workbench-empty-actions">
          <% if active_filters %>
            <%= link_to "Filtreleri temizle", organizer_events_path, class: "btn-outline focus-ring" %>
          <% end %>
          <%= link_to "Etkinlik oluştur", new_organizer_event_path, class: "btn-void focus-ring" %>
        </div>
      </div>
    <% end %>
  </section>
</section>
