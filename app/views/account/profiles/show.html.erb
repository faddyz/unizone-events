<% content_for :title, "Hesap" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/account-settings") %>

<%
  account_name = @user.name.presence || "Unizone üyesi"
  account_initial = (account_name.presence || @user.email).first.upcase
  profile_form_failed = request.path == account_profile_path && @user.errors.any?
  password_form_failed = request.path == account_password_path && @user.errors.any?
  owned_events_count = @user.events.count
  rsvp_count = @user.attendances.count
%>

<section class="account-settings-page">
  <div class="account-settings-shell page-shell">
    <header class="account-settings-header">
      <div>
        <p class="section-eyebrow text-coral">Hesap ayarları</p>
        <h1>Profil ve güvenlik</h1>
        <p>Profilini, iletişim bilgilerini ve şifreni tek ekranda hızlıca güncelle.</p>
      </div>
      <div class="account-status-pill" aria-label="Hesap durumu">
        <span></span>
        <strong>Oturum açık</strong>
      </div>
    </header>

    <div class="account-settings-layout">
      <aside class="account-summary-panel" aria-label="Hesap özeti">
        <div class="account-profile-card">
          <div class="account-avatar"><%= account_initial %></div>
          <div>
            <p class="account-kicker">Üye profili</p>
            <h2><%= account_name %></h2>
            <p><%= @user.email %></p>
          </div>
        </div>

        <dl class="account-summary-stats" aria-label="Hesap aktiviteleri">
          <div>
            <dt>Etkinlik</dt>
            <dd><%= owned_events_count %></dd>
          </div>
          <div>
            <dt>RSVP</dt>
            <dd><%= rsvp_count %></dd>
          </div>
        </dl>

        <nav class="account-settings-nav" aria-label="Ayar bölümleri">
          <a href="#profile-settings" class="focus-ring">
            <%= render "icons/users", class: "size-4" %>
            <span>Profil bilgileri</span>
          </a>
          <a href="#security-settings" class="focus-ring">
            <%= render "icons/check_circle", class: "size-4" %>
            <span>Güvenlik</span>
          </a>
        </nav>

        <div class="account-summary-meta">
          <div>
            <%= render "icons/mail", class: "size-4" %>
            <span>E-posta kayıtlı</span>
          </div>
          <div>
            <%= render "icons/check_circle", class: "size-4" %>
            <span>Şifre koruması aktif</span>
          </div>
          <div>
            <%= render "icons/clock", class: "size-4" %>
            <span>Son güncelleme <%= l(@user.updated_at.to_date, format: :long) %></span>
          </div>
        </div>
      </aside>

      <main class="account-settings-main">
        <section id="profile-settings" class="account-settings-card" aria-labelledby="profile-settings-title">
          <div class="account-card-head">
            <div class="account-card-icon">
              <%= render "icons/users", class: "size-5" %>
            </div>
            <div>
              <p class="section-eyebrow text-coral">Profil</p>
              <h2 id="profile-settings-title">Görünen bilgilerin</h2>
              <p>Adın ve e-postan Unizone içindeki hesap deneyiminde kullanılır.</p>
            </div>
          </div>

          <%= form_with model: @user, url: account_profile_path, method: :patch, class: "account-form" do |form| %>
            <% if profile_form_failed %>
              <div class="account-form-alert" role="alert">
                <strong>Profil bilgilerini kontrol et.</strong>
                <ul>
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="account-form-grid">
              <div class="account-field">
                <%= form.label :name, "Ad", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/users", class: "size-4" %>
                  <%= form.text_field :name,
                        autocomplete: "name",
                        class: "account-input #{profile_form_failed && @user.errors[:name].any? ? "is-invalid" : ""}",
                        aria: { describedby: profile_form_failed && @user.errors[:name].any? ? "profile-name-error" : "profile-name-hint" } %>
                </div>
                <% if profile_form_failed && @user.errors[:name].any? %>
                  <p id="profile-name-error" class="account-field-error"><%= @user.errors.full_messages_for(:name).to_sentence %></p>
                <% else %>
                  <p id="profile-name-hint" class="account-field-hint">Boş bırakırsan hesap e-postan gösterilir.</p>
                <% end %>
              </div>

              <div class="account-field">
                <%= form.label :email, "E-posta", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/mail", class: "size-4" %>
                  <%= form.email_field :email,
                        autocomplete: "email",
                        required: true,
                        class: "account-input #{profile_form_failed && @user.errors[:email].any? ? "is-invalid" : ""}",
                        aria: { describedby: profile_form_failed && @user.errors[:email].any? ? "profile-email-error" : "profile-email-hint" } %>
                </div>
                <% if profile_form_failed && @user.errors[:email].any? %>
                  <p id="profile-email-error" class="account-field-error"><%= @user.errors.full_messages_for(:email).to_sentence %></p>
                <% else %>
                  <p id="profile-email-hint" class="account-field-hint">E-posta değiştirirken mevcut şifren gerekir.</p>
                <% end %>
              </div>

              <div class="account-field account-field-wide">
                <%= form.label :current_password, "Mevcut şifre", for: "profile_current_password", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/check_circle", class: "size-4" %>
                  <%= form.password_field :current_password,
                        id: "profile_current_password",
                        autocomplete: "current-password",
                        class: "account-input #{profile_form_failed && @user.errors[:current_password].any? ? "is-invalid" : ""}",
                        aria: { describedby: profile_form_failed && @user.errors[:current_password].any? ? "profile-current-password-error" : "profile-current-password-hint" } %>
                </div>
                <% if profile_form_failed && @user.errors[:current_password].any? %>
                  <p id="profile-current-password-error" class="account-field-error"><%= @user.errors.full_messages_for(:current_password).to_sentence %></p>
                <% else %>
                  <p id="profile-current-password-hint" class="account-field-hint">Yalnızca e-posta adresini değiştirirken doldur.</p>
                <% end %>
              </div>
            </div>

            <div class="account-form-actions">
              <p>Profil değişiklikleri kaydedildiğinde aynı oturumla devam edersin.</p>
              <%= form.submit "Profili kaydet", class: "btn-void cursor-pointer border-0 focus-ring" %>
            </div>
          <% end %>
        </section>

        <section id="security-settings" class="account-settings-card" aria-labelledby="security-settings-title">
          <div class="account-card-head">
            <div class="account-card-icon">
              <%= render "icons/check_circle", class: "size-5" %>
            </div>
            <div>
              <p class="section-eyebrow text-coral">Güvenlik</p>
              <h2 id="security-settings-title">Şifreyi güncelle</h2>
              <p>Şifre değişikliği ayrı tutulur; profilini düzenlerken yanlışlıkla etkilenmez.</p>
            </div>
          </div>

          <%= form_with model: @user, url: account_password_path, method: :patch, class: "account-form" do |form| %>
            <% if password_form_failed %>
              <div class="account-form-alert" role="alert">
                <strong>Şifre bilgilerini kontrol et.</strong>
                <ul>
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="account-security-note">
              <%= render "icons/info", class: "size-4" %>
              <p>Yeni şifreni kaydetmek için mevcut şifreni doğrulaman gerekir.</p>
            </div>

            <div class="account-form-grid">
              <div class="account-field">
                <%= form.label :current_password, "Mevcut şifre", for: "security_current_password", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/check_circle", class: "size-4" %>
                  <%= form.password_field :current_password,
                        id: "security_current_password",
                        autocomplete: "current-password",
                        required: true,
                        class: "account-input #{password_form_failed && @user.errors[:current_password].any? ? "is-invalid" : ""}",
                        aria: { describedby: password_form_failed && @user.errors[:current_password].any? ? "security-current-password-error" : "security-current-password-hint" } %>
                </div>
                <% if password_form_failed && @user.errors[:current_password].any? %>
                  <p id="security-current-password-error" class="account-field-error"><%= @user.errors.full_messages_for(:current_password).to_sentence %></p>
                <% else %>
                  <p id="security-current-password-hint" class="account-field-hint">Hesabın sana ait olduğunu doğrular.</p>
                <% end %>
              </div>

              <div class="account-field">
                <%= form.label :password, "Yeni şifre", for: "security_password", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/sparkles", class: "size-4" %>
                  <%= form.password_field :password,
                        id: "security_password",
                        autocomplete: "new-password",
                        required: true,
                        class: "account-input #{password_form_failed && @user.errors[:password].any? ? "is-invalid" : ""}",
                        aria: { describedby: password_form_failed && @user.errors[:password].any? ? "security-password-error" : "security-password-hint" } %>
                </div>
                <% if password_form_failed && @user.errors[:password].any? %>
                  <p id="security-password-error" class="account-field-error"><%= @user.errors.full_messages_for(:password).to_sentence %></p>
                <% else %>
                  <p id="security-password-hint" class="account-field-hint">En az 6 karakter kullan.</p>
                <% end %>
              </div>

              <div class="account-field account-field-wide">
                <%= form.label :password_confirmation, "Yeni şifre tekrarı", for: "security_password_confirmation", class: "account-label" %>
                <div class="account-input-wrap">
                  <%= render "icons/check_circle", class: "size-4" %>
                  <%= form.password_field :password_confirmation,
                        id: "security_password_confirmation",
                        autocomplete: "new-password",
                        required: true,
                        class: "account-input #{password_form_failed && @user.errors[:password_confirmation].any? ? "is-invalid" : ""}",
                        aria: { describedby: password_form_failed && @user.errors[:password_confirmation].any? ? "security-password-confirmation-error" : "security-password-confirmation-hint" } %>
                </div>
                <% if password_form_failed && @user.errors[:password_confirmation].any? %>
                  <p id="security-password-confirmation-error" class="account-field-error"><%= @user.errors.full_messages_for(:password_confirmation).to_sentence %></p>
                <% else %>
                  <p id="security-password-confirmation-hint" class="account-field-hint">Yazım hatalarını yakalamak için tekrar gir.</p>
                <% end %>
              </div>
            </div>

            <div class="account-form-actions">
              <p>Şifre güncellendiğinde oturumun korunur ve devam edersin.</p>
              <%= form.submit "Şifreyi güncelle", class: "btn-electric cursor-pointer border-0 focus-ring" %>
            </div>
          <% end %>
        </section>
      </main>
    </div>
  </div>
</section>
