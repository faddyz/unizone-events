<% content_for :title, "Hesap" %>

<section class="page-shell space-y-8">
  <%= render "shared/page_header",
        eyebrow: "Hesap",
        title: "Profil ve güvenlik",
        description: "Unizone hesabını güncel tut; e-posta ve şifre değişikliklerini güvenle yönet." %>

  <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
    <aside class="cinema-panel is-dark rounded-[1.35rem] p-6">
      <div class="grid size-20 place-items-center rounded-full bg-citron font-display text-3xl font-extrabold text-stone-950 shadow-[8px_8px_0_rgba(255,255,255,0.14)]">
        <%= (@user.name.presence || @user.email).first.upcase %>
      </div>
      <p class="section-eyebrow mt-8 text-citron">Profil</p>
      <h2 class="font-display mt-2 text-4xl font-extrabold tracking-tight"><%= @user.name.presence || "Unizone üyesi" %></h2>
      <p class="mt-3 text-sm font-medium leading-6 text-white/65"><%= @user.email %></p>
      <div class="mt-6 grid grid-cols-2 gap-3">
        <div class="rounded-xl border border-white/10 bg-white/[0.06] p-4">
          <p class="font-display text-3xl font-extrabold"><%= @user.events.count %></p>
          <p class="section-eyebrow mt-1 text-white/45">Etkinlik</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.06] p-4">
          <p class="font-display text-3xl font-extrabold"><%= @user.attendances.count %></p>
          <p class="section-eyebrow mt-1 text-white/45">RSVP</p>
        </div>
      </div>
    </aside>

    <div class="grid gap-6">
      <section class="cinema-panel rounded-[1.35rem] p-6">
        <h2 class="font-display text-2xl font-extrabold tracking-tight text-stone-950">Profil bilgileri</h2>

        <%= form_with model: @user, url: account_profile_path, method: :patch, class: "mt-5 space-y-4" do |form| %>
          <div>
            <%= form.label :name, "Ad", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.text_field :name, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <div>
            <%= form.label :email, "E-posta", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.email_field :email, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <div>
            <%= form.label :current_password, "E-posta değişikliği için mevcut şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.password_field :current_password, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <%= form.submit "Profili kaydet", class: "btn-void cursor-pointer border-0 focus-ring" %>
        <% end %>
      </section>

      <section class="cinema-panel rounded-[1.35rem] p-6">
        <h2 class="font-display text-2xl font-extrabold tracking-tight text-stone-950">Şifre</h2>

        <%= form_with model: @user, url: account_password_path, method: :patch, class: "mt-5 space-y-4" do |form| %>
          <div>
            <%= form.label :current_password, "Mevcut şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.password_field :current_password, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <div>
            <%= form.label :password, "Yeni şifre", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.password_field :password, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <div>
            <%= form.label :password_confirmation, "Yeni şifre tekrarı", class: "mb-2 block section-eyebrow text-stone-500" %>
            <%= form.password_field :password_confirmation, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
          </div>
          <%= form.submit "Şifreyi güncelle", class: "btn-electric cursor-pointer border-0 focus-ring" %>
        <% end %>
      </section>
    </div>
  </div>
</section>
