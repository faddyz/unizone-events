<% content_for :title, "Planlarım" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/member-workbench") %>

<% user_label = current_user.name.presence || current_user.email %>
<% next_event = @next_plan&.event %>

<section class="member-workbench dashboard-page page-shell">
  <header class="workbench-hero dashboard-hero">
    <div class="soft-grid absolute inset-0 opacity-35"></div>
    <div class="workbench-hero-copy">
      <p class="section-eyebrow text-citron">Planlarım</p>
      <h1>Hoş geldin, <span><%= user_label %></span></h1>
      <p>Katıldığın etkinlikleri, yaklaşan planlarını ve oluşturduğun organizasyonları tek panelden yönet.</p>

      <div class="workbench-hero-actions">
        <%= link_to explore_events_path, class: "workbench-primary-action focus-ring" do %>
          <%= render "icons/calendar", class: "size-4" %>
          <span>Etkinlik bul</span>
        <% end %>
        <%= link_to new_organizer_event_path, class: "workbench-secondary-action focus-ring" do %>
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          <span>Etkinlik oluştur</span>
        <% end %>
      </div>
    </div>

    <aside class="dashboard-next">
      <p class="section-eyebrow text-white/42">Sıradaki Plan</p>
      <% if next_event.present? %>
        <div class="dashboard-next-date">
          <span><%= next_event.date.strftime("%b") %></span>
          <strong><%= next_event.date.strftime("%-d") %></strong>
        </div>
        <h2><%= link_to next_event.title, event_path(next_event), class: "focus-ring" %></h2>
        <p><%= l(next_event.date, format: :long) %> · <%= event_place_text(next_event) %></p>
        <span class="<%= attendance_status_badge_classes(@next_plan.status) %>"><%= attendance_status_label(@next_plan.status) %></span>
      <% else %>
        <div class="dashboard-next-empty">
          <span class="dashboard-empty-dot"></span>
          <h2>Takvimin seni bekliyor.</h2>
          <p>İlk etkinliğini seç, planını oluştur ve Unizone akışına dahil ol.</p>
          <%= link_to "Etkinlikleri Keşfet", explore_events_path, class: "btn-electric focus-ring" %>
        </div>
      <% end %>
    </aside>
  </header>

  <div class="workbench-signal-grid">
    <% [
      [ "Yaklaşan Planların", @upcoming_rsvps.count, "Katılım verdiğin aktif etkinlikler" ],
      [ "Toplam Katılım", @rsvps.count, "İşaretlediğin etkinlikler" ],
      [ "Organizasyonların", @owned_events.count, "Oluşturduğun etkinlik taslakları" ],
      [ "Yayındaki etkinlikler", @live_events_count, "Herkese açık aktif organizasyonlar" ]
    ].each_with_index do |(label, value, hint), index| %>
      <article class="workbench-signal-card is-tone-<%= index + 1 %>">
        <span class="workbench-signal-dot"></span>
        <p><%= label %></p>
        <strong><%= value %></strong>
        <small><%= hint %></small>
      </article>
    <% end %>
  </div>

  <div class="dashboard-grid">
    <section class="workbench-panel dashboard-timeline-panel">
      <div class="workbench-section-head">
        <div>
          <p class="section-eyebrow text-coral">Takvim</p>
          <h2>Yaklaşan Planların</h2>
        </div>
        <%= link_to "Etkinlik Bul", explore_events_path, class: "workbench-link focus-ring" %>
      </div>

      <% if @upcoming_rsvps.any? %>
        <div class="dashboard-timeline">
          <% @upcoming_rsvps.each do |attendance| %>
            <% event = attendance.event %>
            <article class="dashboard-timeline-item">
              <time datetime="<%= event.date.iso8601 %>">
                <span><%= event.date.strftime("%b") %></span>
                <strong><%= event.date.strftime("%-d") %></strong>
              </time>
              <div>
                <div class="dashboard-item-kicker">
                  <span><%= event.date.strftime("%H:%M") %></span>
                  <span class="<%= attendance_status_badge_classes(attendance.status) %>"><%= attendance_status_label(attendance.status) %></span>
                </div>
                <h3><%= link_to event.title, event_path(event), class: "focus-ring" %></h3>
                <p><%= event_place_text(event) %></p>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="workbench-empty-state">
          <span class="dashboard-empty-dot"></span>
          <h3>Takvimin henüz boş.</h3>
          <p>Şehirdeki etkinlikleri keşfet, ilgini çekenlere katılım ver ve takvimini doldur.</p>
          <%= link_to "Etkinlik keşfet", explore_events_path, class: "btn-void focus-ring" %>
        </div>
      <% end %>
    </section>

    <aside class="dashboard-side-stack">
      <section class="workbench-panel">
        <div class="workbench-section-head">
          <div>
            <p class="section-eyebrow text-coral">Organizatör</p>
            <h2>Etkinlik Yönetimi</h2>
          </div>
          <%= link_to "Tümünü Aç", organizer_events_path, class: "workbench-link focus-ring" %>
        </div>

        <% if @owned_events.any? %>
          <div class="dashboard-mini-list">
            <% @owned_events.limit(4).each do |event| %>
              <article class="dashboard-mini-event">
                <div class="dashboard-mini-poster <%= event_poster_background_classes(event) %>">
                  <% if event.image.attached? %>
                    <%= event_image_tag event,
                          :thumb,
                          alt: "",
                          loading: "lazy",
                          sizes: "4rem",
                          class_name: "",
                          aria: { hidden: true } %>
                  <% else %>
                    <div class="poster-noise absolute inset-0"></div>
                  <% end %>
                </div>
                <div>
                  <span class="<%= event_status_badge_classes(event) %>"><%= event_status_label(event) %></span>
                  <h3><%= link_to event.title, organizer_event_path(event), class: "focus-ring" %></h3>
                  <p><%= event_lifecycle_hint(event) %></p>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="workbench-empty-state is-compact">
            <h3>Henüz bir etkinlik oluşturmadın.</h3>
            <p>Fikrini taslağa dönüştür, detayları ekle ve yayına çıkmak için incelemeye gönder.</p>
            <%= link_to "İlk Etkinliğini Oluştur", new_organizer_event_path, class: "btn-void focus-ring" %>
          </div>
        <% end %>
      </section>

      <section class="workbench-panel">
        <div class="workbench-section-head">
          <div>
            <p class="section-eyebrow text-coral">Hareket</p>
            <h2>Son Katılımlar</h2>
          </div>
        </div>

        <% if @recent_rsvps.any? %>
          <div class="dashboard-activity-list">
            <% @recent_rsvps.each do |attendance| %>
              <article>
                <span class="dashboard-activity-dot"></span>
                <div>
                  <h3><%= link_to attendance.event.title, event_path(attendance.event), class: "focus-ring" %></h3>
                  <p><%= attendance_status_label(attendance.status) %> · <%= l(attendance.updated_at, format: :short) %></p>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="workbench-empty-state is-compact">
            <h3>Henüz hareket yok</h3>
            <p>RSVP verdiğinde güncel durumların burada görünür.</p>
          </div>
        <% end %>
      </section>
    </aside>
  </div>
</section>
