<% content_for :title, "Etkinlikleri Keşfet" %>
<% content_for :stylesheets, page_stylesheet_tags("components/cards", "components/carousel", "pages/explore") %>

<%
  view_mode = params[:view] == "list" ? "list" : "grid"
  selected_categories = Array(params[:category]).flatten.reject(&:blank?)
%>

<div class="explore-page">
  <header class="page-shell explore-header">
    <div class="explore-header-copy">
      <p class="section-eyebrow text-coral">Keşfet</p>
      <h1>Tüm etkinlikleri keşfet.</h1>
      
    </div>
  </header>

  <section class="page-shell explore-category-shell" aria-label="Kategoriler" data-controller="carousel">
    <div class="explore-category-head">
      <span>Kategoriler</span>
      <div class="explore-category-actions">
        <button type="button" class="carousel-button explore-category-button is-left focus-ring" data-action="carousel#previous" aria-label="Önceki kategoriler">
          <%= render "icons/arrow_left", class: "size-4" %>
        </button>
        <button type="button" class="carousel-button explore-category-button is-right focus-ring" data-action="carousel#next" aria-label="Sonraki kategoriler">
          <%= render "icons/arrow_left", class: "size-4 rotate-180" %>
        </button>
      </div>
    </div>

    <div class="explore-category-stage">
      <button type="button" class="carousel-side-button explore-category-side is-left focus-ring" data-action="carousel#previous" aria-label="Önceki kategoriler">
        <%= render "icons/arrow_left", class: "size-5" %>
      </button>

      <div class="explore-category-strip"
           data-carousel-target="viewport"
           data-controller="drag-scroll"
           data-action="pointerdown->drag-scroll#start pointermove->drag-scroll#move pointerup->drag-scroll#stop pointercancel->drag-scroll#stop pointerleave->drag-scroll#stop dragstart->drag-scroll#preventNativeDrag">
        <%= link_to explore_events_path(explore_filter_params_with(category: nil)),
              class: "explore-category-pill #{selected_categories.blank? ? "is-active" : ""} focus-ring",
              draggable: "false" do %>
          <span class="explore-category-icon"><%= render "icons/sparkles", class: "size-4" %></span>
          <span>Tümü</span>
        <% end %>

        <% @categories.each do |label, category| %>
          <%= link_to explore_events_path(explore_filter_params_with(category: category)),
                class: "explore-category-pill #{event_category_tone_class(category)} #{selected_categories.include?(category) ? "is-active" : ""} focus-ring",
                draggable: "false" do %>
            <span class="explore-category-icon"><%= render "icons/#{event_category_icon(category)}", class: "size-4" %></span>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </div>

      <button type="button" class="carousel-side-button explore-category-side is-right focus-ring" data-action="carousel#next" aria-label="Sonraki kategoriler">
        <%= render "icons/arrow_left", class: "size-5 rotate-180" %>
      </button>
    </div>
  </section>

  <section class="page-shell explore-workbench">
    <%= render "filters" %>

    <% if @events.any? %>
      <div class="explore-results explore-results-<%= view_mode %>" data-view-mode="<%= view_mode %>">
        <% @events.each_with_index do |event, index| %>
          <% if view_mode == "list" %>
            <% going_count = event_attendance_count(event) %>
            <% capacity = event.capacity.to_i.positive? ? event.capacity.to_i : nil %>
            <% spots_left = capacity ? [capacity - going_count, 0].max : nil %>

            <article class="explore-list-card animate-rise-in" style="animation-delay: <%= index * 45 %>ms">
              <%= link_to event_path(event), class: "explore-list-poster focus-ring #{event_poster_background_classes(event)}" do %>
                <div class="poster-art absolute inset-0 opacity-100"></div>
                <% if event.image.attached? %>
                  <%= event_image_tag event,
                        :list,
                        alt: event.title,
                        loading: "lazy",
                        sizes: "(min-width: 1024px) 12.5rem, (min-width: 640px) 12rem, 92vw",
                        class_name: "event-poster-image event-poster-image-main absolute inset-0 h-full w-full" %>
                <% end %>
                <span class="explore-list-date">
                  <small><%= event.date.strftime("%b") %></small>
                  <strong><%= event.date.strftime("%-d") %></strong>
                </span>
              <% end %>

              <div class="explore-list-main">
                <div class="explore-list-tags">
                  <span class="<%= event_category_badge_classes(event) %>"><%= event_category_title(event) %></span>
                  <span class="explore-list-time"><%= event.date.strftime("%d %b, %H:%M") %></span>
                </div>

                <h2>
                  <%= link_to event.title, event_path(event), class: "focus-ring" %>
                </h2>
                <p><%= truncate(event.description.to_s.squish, length: 150) %></p>
              </div>

              <dl class="explore-list-facts">
                <div>
                  <dt>Mekan / Şehir</dt>
                  <dd><%= truncate(event_place_text(event), length: 42) %></dd>
                </div>
                <div>
                  <dt>Ücret</dt>
                  <dd><%= event_price_text(event) %></dd>
                </div>
                <div>
                  <dt><%= capacity ? "Kontenjan" : "Katılım" %></dt>
                  <dd><%= capacity ? "#{spots_left} yer kaldı" : (going_count.positive? ? "#{going_count} gidiyor" : "İlk sen katıl") %></dd>
                </div>
              </dl>

              <%= link_to event_path(event), class: "explore-list-action focus-ring", aria: { label: "#{event.title} detayları" } do %>
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              <% end %>
            </article>
          <% else %>
            <%= render "events/event_card", event: event, index: index %>
          <% end %>
        <% end %>
      </div>

      <div class="explore-pagination">
        <%= paginate @events, theme: "tailwind" %>
      </div>
    <% else %>
      <% action = capture do %>
        <div class="explore-empty-actions">
          <%= link_to "Filtreleri temizle", explore_events_path, class: "btn-outline focus-ring" %>
          <%= link_to "Etkinlik oluştur", new_organizer_event_path, class: "btn-void focus-ring" if user_signed_in? %>
        </div>
      <% end %>
      <%= render "shared/empty_state",
            title: "Henüz eşleşen etkinlik yok",
            description: "Filtreleri biraz genişlet veya başka bir kategori dene.",
            action: action,
            class_name: "explore-empty-state" %>
    <% end %>
  </section>
</div>
