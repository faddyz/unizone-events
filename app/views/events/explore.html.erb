<% content_for :title, "Etkinlikleri Keşfet" %>

<section class="page-shell space-y-7">
  <header class="relative overflow-hidden rounded-[1.5rem] bg-ink p-6 text-white md:p-8">
    <div class="soft-grid absolute inset-0 opacity-40"></div>
    <div class="hero-energy absolute inset-0 opacity-80"></div>
    <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <p class="section-eyebrow text-citron">Keşfet</p>
        <h1 class="font-display mt-3 max-w-4xl text-4xl font-extrabold leading-[0.95] tracking-tight sm:text-6xl">Grup sohbetinden çıkmaya değecek etkinlikler.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-white/68">Ruh haline, kategoriye, mekana veya merak ettiğin konuya göre şehirdeki planları ara.</p>
      </div>
      <p class="w-fit rounded-full bg-white px-4 py-3 font-mono text-xs font-black uppercase tracking-[0.12em] text-stone-950"><%= @events.total_count %> sonuç</p>
    </div>
  </header>

  <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-none">
    <%= link_to "Tümü", explore_events_path, class: "category-pill bg-stone-950 text-white focus-ring" %>
    <% Event.categories.keys.each do |category| %>
      <%= link_to explore_events_path(category: category), class: "category-pill #{event_category_badge_classes(category)} focus-ring" do %>
        <span class="category-pill-dot"></span>
        <span><%= event_category_title(category) %></span>
      <% end %>
    <% end %>
  </div>

  <%= render "filters" %>

  <% if @events.any? %>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      <% @events.each_with_index do |event, index| %>
        <%= render "events/event_card", event: event, index: index %>
      <% end %>
    </div>
    <%= paginate @events, theme: "tailwind" %>
  <% else %>
    <% action = capture do %>
      <%= link_to "Filtreleri temizle", explore_events_path, class: "btn-outline focus-ring" %>
    <% end %>
    <%= render "shared/empty_state", title: "Henüz eşleşen etkinlik yok", description: "Daha geniş bir arama dene veya başka bir kategori seç.", action: action %>
  <% end %>
</section>
