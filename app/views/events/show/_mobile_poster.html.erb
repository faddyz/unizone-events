  <% if show.poster? %>
    <section class="event-mobile-poster-shell page-shell relative z-20 lg:hidden">
      <button type="button"
              class="event-mobile-poster-card <%= event_poster_background_classes(show.event) %> focus-ring"
              data-action="poster-lightbox#open"
              aria-haspopup="dialog"
              aria-controls="event-poster-lightbox"
              aria-label="<%= show.display_title %> afişini göster">
        <span class="event-mobile-poster-thumb">
          <%= event_poster_image_tag show.event,
                :thumb,
                alt: "",
                loading: "lazy",
                sizes: "4.5rem",
                class_name: "event-mobile-poster-thumb-image",
                aria: { hidden: true } %>
        </span>
        <span class="event-mobile-poster-copy">
          <span>Afişi göster</span>
          <strong><%= show.display_title %></strong>
        </span>
        <span class="event-mobile-poster-icon" aria-hidden="true">
          <%= render "icons/image", class: "size-4" %>
        </span>
      </button>
    </section>
  <% end %>
