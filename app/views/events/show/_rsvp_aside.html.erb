    <aside class="event-rsvp-aside space-y-4 lg:sticky lg:top-28">
      <section class="event-action-card">
        <p class="section-eyebrow text-coral">Aksiyon</p>
        <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Bu etkinlikte var mısın?</h2>
        <p class="mt-2 text-sm font-semibold leading-6 text-stone-500"><%= show.preview_mode ? "Bu alan yayındaki sayfanın aksiyon düzenini gösterir." : (show.signed_in? ? "Katılacağını netleştir, ilgini göster ya da sana uygun değilse pas geç." : "Katılımını bildirmek ve etkinliği hesabında takip etmek için giriş yap.") %></p>

        <% if show.preview_mode %>
          <%= render "events/show/rsvp_preview_actions", show: show %>
        <% else %>
          <%= render "events/show/rsvp_live_actions", show: show %>
          <%= render "events/show/rsvp_stats", show: show %>
        <% end %>
      </section>

      <%= render "events/show/management_panel", show: show %>
    </aside>
