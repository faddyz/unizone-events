  <section class="event-show-hero relative isolate overflow-hidden bg-void text-white">
    <div class="absolute inset-0 <%= event_poster_background_classes(show.event) %> opacity-80"></div>
    <div class="poster-noise absolute inset-0"></div>
    <div class="hero-atmosphere absolute inset-0 opacity-70"></div>
    <div class="hero-stage-wash absolute inset-0 opacity-65"></div>
    <div class="hero-ribbon hero-ribbon-citron"></div>
    <div class="hero-ribbon hero-ribbon-blue"></div>
    <div class="hero-glow-field absolute inset-0"></div>
    <div class="soft-grid absolute inset-0 opacity-45"></div>
    <div class="hero-energy absolute inset-0"></div>
    <div class="hero-noise absolute inset-0"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-void via-stone-950/70 to-stone-950/28"></div>

    <% if show.preview_mode %>
      <div class="event-preview-banner page-shell relative z-20">
        <div class="event-preview-banner-inner">
          <div>
            <p class="section-eyebrow text-citron">Önizleme modu</p>
            <strong>Bu sayfa sadece etkinlik sahibi ve adminler tarafından görülebilir.</strong>
            <span>Yayına alınana kadar keşifte listelenmez; katılım, paylaşım ve bilet aksiyonları kapalıdır.</span>
          </div>
          <%= link_to show.preview_back_label, show.preview_back_path, class: "event-preview-back focus-ring" %>
        </div>
      </div>
    <% end %>

    <div class="page-shell relative z-10 grid min-h-[46rem] content-end gap-10 pb-24 pt-32 lg:min-h-[50rem] lg:grid-cols-[minmax(0,1fr)_25rem] lg:items-end lg:pb-28">
      <div class="hero-copy max-w-5xl">
        <%= link_to show.preview_back_path, class: "mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.07] px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-white/72 backdrop-blur-xl transition hover:border-citron/60 hover:text-citron focus-ring" do %>
          <%= render "icons/arrow_left", class: "size-4" %>
          <%= show.preview_back_label %>
        <% end %>

        <div class="flex flex-wrap items-center gap-2">
          <span class="<%= event_category_badge_classes(show.event) %>"><%= event_category_title(show.event) %></span>
          <% unless show.event.published? %>
            <span class="<%= event_status_badge_classes(show.event) %>"><%= event_status_label(show.event) %></span>
          <% end %>
          <span class="rounded-full border border-white/12 bg-white/[0.08] px-3 py-1 font-mono text-[0.65rem] font-black uppercase tracking-[0.12em] text-white/70"><%= show.event.date.strftime("%H:%M") %></span>
        </div>

        <h1 class="event-show-title <%= show.title_density_class %> mt-5 max-w-5xl text-pretty font-display font-extrabold leading-[0.9] tracking-tight <%= show.title_size_class %>">
          <%= show.display_title %>
        </h1>
        <p class="mt-6 max-w-3xl text-base font-medium leading-7 text-white/74 sm:text-xl sm:leading-8">
          <%= truncate(show.display_description.squish, length: 190) %>
        </p>

        <%= render "events/show/hero_actions", show: show %>
        <%= render "events/show/hero_attendance_summary", show: show %>
      </div>

      <%= render "events/show/hero_poster_card", show: show %>
    </div>
  </section>
