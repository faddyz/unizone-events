  <div class="event-mobile-actions lg:hidden">
    <% if show.preview_mode %>
      <button type="button" class="event-mobile-primary is-preview-disabled" disabled aria-disabled="true">
        <%= show.public_action_label %>
      </button>
      <%= link_to show.preview_back_path, class: "event-mobile-icon focus-ring", aria: { label: show.preview_back_label } do %>
        <%= render "icons/arrow_left", class: "size-5" %>
      <% end %>
    <% elsif show.ticket_url %>
      <%= link_to show.external_action_label,
            show.ticket_url,
            target: "_blank",
            rel: "noopener",
            class: "event-mobile-primary focus-ring",
            data: {
              action: "external-redirect#open",
              external_redirect_url_param: show.ticket_url
            },
            aria: {
              haspopup: "dialog",
              controls: "event-external-redirect-dialog"
            } %>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% elsif show.signed_in? %>
      <button type="button"
              class="event-mobile-primary <%= show.going_selected? ? "is-active" : "" %> focus-ring"
              data-attendance-status="going"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="Katıl!"
              data-attendance-selected-label="Yerini aldın!"
              data-action="click->attendance#update"
              aria-pressed="<%= show.going_selected? %>">
        <span data-attendance-state><%= show.going_selected? ? "Yerini aldın!" : "Katıl!" %></span>
      </button>
      <button type="button"
              class="event-mobile-secondary <%= show.interested_selected? ? "is-active" : "" %> focus-ring"
              data-attendance-status="interested"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="İlgilen!"
              data-attendance-selected-label="İlgileniyorsun!"
              data-attendance-visible-when="none interested"
              data-action="click->attendance#update"
              aria-pressed="<%= show.interested_selected? %>"
              <%= "hidden" if show.going_selected? || show.not_going_selected? %>>
        <span data-attendance-state><%= show.interested_selected? ? "İlgileniyorsun!" : "İlgilen!" %></span>
      </button>
      <button type="button"
              class="event-mobile-secondary <%= show.not_going_selected? ? "is-active" : "" %> focus-ring"
              data-attendance-status="not_going"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="Pas geç."
              data-attendance-selected-label="Pas geçildi."
              data-attendance-visible-when="not_going"
              data-action="click->attendance#update"
              aria-pressed="<%= show.not_going_selected? %>"
              <%= "hidden" unless show.not_going_selected? %>>
        <span data-attendance-state><%= show.not_going_selected? ? "Pas geçildi." : "Pas geç." %></span>
      </button>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% else %>
      <%= link_to "Giriş yap", new_user_session_path, class: "event-mobile-primary focus-ring" %>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% end %>
  </div>
