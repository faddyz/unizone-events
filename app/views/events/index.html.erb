<% content_for :title, "Unizone" %>
<% content_for :transparent_nav, true %>

<% category_cards = [
  { key: "music", icon: "music", mood: "Canlı sahne", note: "Konserler, DJ setleri ve geceye tempo veren etkinlikler.", class_name: "is-citron" },
  { key: "technology", icon: "cpu", mood: "Yeni fikirler", note: "Yazılım, ürün, yapay zeka ve dijital kültür buluşmaları.", class_name: "is-blue" },
  { key: "workshop", icon: "edit", mood: "Üret ve öğren", note: "Atölyeler, pratik seanslar ve beraber üretme alanları.", class_name: "is-mint" },
  { key: "festival", icon: "sparkles", mood: "Açık hava", note: "Kalabalık, renkli ve uzun soluklu şehir planları.", class_name: "is-ember" },
  { key: "art", icon: "palette", mood: "Kültür rotası", note: "Sergi, tasarım, tiyatro ve bağımsız sahne işleri.", class_name: "is-grape" },
  { key: "networking", icon: "users", mood: "Yeni çevre", note: "İnsanlarla tanışmak, ekip bulmak ve fikir paylaşmak için.", class_name: "is-ice" }
] %>
<% upcoming_events = @events.first(8) %>

<%= render "events/hero" %>

<section class="page-shell mt-8 space-y-7 lg:mt-10" data-controller="carousel">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="section-eyebrow text-coral">Öne çıkanlar</p>
      <h2 class="font-display mt-2 text-3xl font-bold tracking-tight text-stone-950 lg:text-5xl">Şehrin radarındaki planlar</h2>
      <p class="mt-2 max-w-xl text-sm font-semibold leading-6 text-stone-500">Şu an öne çıkan etkinliklere bak, planını yap.</p>
    </div>
    <%= link_to explore_events_path(sort_by: "popular"), class: "section-cta focus-ring" do %>
      <span>Tümünü gör</span>
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    <% end %>
  </div>

  <% if @featured_events.any? %>
    <div class="carousel-stage">
      <button type="button" class="carousel-side-button is-left focus-ring" aria-label="Önceki etkinlikler" data-action="carousel#previous">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="carousel-viewport scrollbar-none" data-carousel-target="viewport">
        <div class="featured-carousel-track">
          <% @featured_events.each_with_index do |event, index| %>
            <div class="featured-carousel-slide">
              <%= render "events/event_card", event: event, featured: true, index: index %>
            </div>
          <% end %>
        </div>
      </div>
      <button type="button" class="carousel-side-button is-right focus-ring" aria-label="Sonraki etkinlikler" data-action="carousel#next">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 6 6 6-6 6"/></svg>
      </button>
    </div>
  <% end %>
</section>

<section class="home-category-band mt-16 py-16 text-white">
  <div class="page-shell space-y-7" data-controller="carousel">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="section-eyebrow text-citron">Kategoriler</p>
        <h2 class="font-display mt-2 text-3xl font-bold tracking-tight lg:text-5xl">Modunu seç</h2>
        <p class="mt-2 max-w-xl text-sm font-semibold leading-6 text-white/55">Ne yapmak istiyorsun? Seç ve git.</p>
      </div>
      <%= link_to explore_events_path, class: "section-cta section-cta-dark focus-ring" do %>
        <span>Tüm kategoriler</span>
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      <% end %>
    </div>

    <div class="carousel-stage category-carousel-stage">
      <button type="button" class="carousel-side-button carousel-side-button-dark is-left focus-ring" aria-label="Önceki kategoriler" data-action="carousel#previous">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="carousel-viewport scrollbar-none" data-carousel-target="viewport">
        <div class="category-card-track">
          <% category_cards.each do |card| %>
            <%= link_to explore_events_path(category: card[:key]), class: "home-category-card #{card[:class_name]} focus-ring" do %>
              <span class="home-category-icon">
                <%= render "icons/#{card[:icon]}", class: "size-5" %>
              </span>
              <span class="min-w-0">
                <span class="block font-mono text-[0.64rem] font-black uppercase tracking-[0.16em] text-white/42"><%= card[:mood] %></span>
                <span class="mt-2 block font-body text-xl font-bold"><%= event_category_title(card[:key]) %></span>
                <span class="mt-2 block text-sm font-medium leading-6 text-white/58"><%= card[:note] %></span>
              </span>
              <span class="home-category-arrow" aria-hidden="true">
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
      <button type="button" class="carousel-side-button carousel-side-button-dark is-right focus-ring" aria-label="Sonraki kategoriler" data-action="carousel#next">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 6 6 6-6 6"/></svg>
      </button>
    </div>
  </div>
</section>

<section class="page-shell mt-16 space-y-7" data-controller="carousel">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="section-eyebrow text-emerald-700">Yaklaşan</p>
      <h2 class="font-display mt-2 text-3xl font-bold tracking-tight text-stone-950 lg:text-5xl">Takvimde sırada ne var?</h2>
      <p class="mt-2 max-w-xl text-sm font-semibold leading-6 text-stone-500">Bu hafta yaklaşan etkinliklere bak. Daha fazlası burada.</p>
    </div>
    <%= link_to explore_events_path(date_filter: "upcoming"), class: "section-cta focus-ring" do %>
      <span>Yaklaşanları gör</span>
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    <% end %>
  </div>

  <% if upcoming_events.any? %>
    <div class="carousel-stage">
      <button type="button" class="carousel-side-button is-left focus-ring" aria-label="Önceki yaklaşan etkinlikler" data-action="carousel#previous">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="carousel-viewport scrollbar-none" data-carousel-target="viewport">
        <div class="upcoming-carousel-track">
          <% upcoming_events.each_with_index do |event, index| %>
            <div class="upcoming-carousel-slide">
              <%= render "events/event_card", event: event, compact: true, index: index %>
            </div>
          <% end %>
        </div>
      </div>
      <button type="button" class="carousel-side-button is-right focus-ring" aria-label="Sonraki yaklaşan etkinlikler" data-action="carousel#next">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="m9 6 6 6-6 6"/></svg>
      </button>
    </div>
  <% else %>
    <% action = capture do %>
      <%= link_to "İlk etkinliği oluştur", new_organizer_event_path, class: "btn-void focus-ring" if user_signed_in? %>
    <% end %>
    <%= render "shared/empty_state", title: "Henüz yayında etkinlik yok", description: "Takvimi insanların katılabileceği ilk planla başlat.", action: action %>
  <% end %>
</section>

<section class="page-shell mt-16">
  <div class="home-organizer-cta relative overflow-hidden rounded-[1.25rem] bg-citron p-8 text-stone-950 md:p-10">
    <div class="absolute right-0 top-0 h-full w-1/3 bg-white/20 blur-3xl pointer-events-none"></div>
    <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="section-eyebrow opacity-70">Organizatörler için</p>
        <h2 class="font-display mt-2 text-3xl font-bold tracking-tight md:text-4xl">Kendi etkinliğini şehirle buluştur.</h2>
        <p class="mt-3 max-w-2xl text-sm font-semibold leading-6 text-stone-700">Etkinlik sayfanı oluştur, detayları düzenle ve hazır olduğunda yayına almak için incelemeye gönder.</p>
      </div>
      <%= link_to new_organizer_event_path, class: "btn-void focus-ring" do %>
        <span>Etkinlik oluştur</span>
        <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      <% end %>
    </div>
  </div>
</section>
