<section class="event-form-step" data-wizard-target="step">
  <div class="event-form-step-intro">
    <p class="section-eyebrow text-coral">Temel bilgiler</p>
    <h3>Güçlü bir başlangıç yap.</h3>
    <p>Kısa ve net bir başlık, doğru kategoriyle birleştiğinde etkinliğin daha kolay fark edilir..</p>
  </div>

  <div class="event-form-grid">
    <div class="event-form-field md:col-span-2">
      <%= form.label :title, "Etkinlik adı", class: "event-form-label" %>
      <%= form.text_field :title,
            class: event_form_control_classes(model, :title),
            placeholder: "Gece yarısı çatı konseri",
            aria: event_form_aria(model, :title, describedby: "event-title-hint"),
            data: { event_preview_target: "title", wizard_required: "true" } %>
      <p id="event-title-hint" class="event-form-hint">Başlık, etkinliğinin ilk dikkat çeken alanıdır; sade ve güçlü olsun.</p>
      <% if event_form_field_error?(model, :title) %>
        <p id="<%= event_form_field_error_id(:title) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :title) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :category, "Kategori", class: "event-form-label" %>
      <%= form.select :category,
            Event.categories.keys.map { |category| [event_category_title(category), category] },
            {},
            class: event_form_control_classes(model, :category),
            aria: event_form_aria(model, :category),
            data: { event_preview_target: "category", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :category) %>
        <p id="<%= event_form_field_error_id(:category) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :category) %></p>
      <% end %>
    </div>

    <div class="event-form-note">
      <%= render "icons/info", class: "size-5" %>
      <p>Kategori, etkinliğinin doğru kitleye ulaşmasına yardımcı olur.</p>
    </div>
  </div>
</section>

<section class="event-form-step" data-wizard-target="step">
  <div class="event-form-step-intro">
    <p class="section-eyebrow text-coral">Zaman ve yer</p>
    <h3>Etkinliğin ne zaman ve nerede olacağını netleştir.</h3>
    <p>Belirsiz tarih, saat veya konum iyi bir etkinliğin bile ertelenmesine neden olabilir.</p>
  </div>

  <div class="event-form-grid">
    <div class="event-form-field">
      <%= form.label :date, "Tarih ve saat", class: "event-form-label" %>
      <%= form.datetime_local_field :date,
            class: event_form_control_classes(model, :date),
            aria: event_form_aria(model, :date),
            data: { event_preview_target: "date", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :date) %>
        <p id="<%= event_form_field_error_id(:date) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :date) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :city, "Şehir", class: "event-form-label" %>
      <%= form.select :city,
            Event::CITY_OPTIONS,
            {},
            class: event_form_control_classes(model, :city),
            aria: event_form_aria(model, :city),
            data: { event_preview_target: "city", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :city) %>
        <p id="<%= event_form_field_error_id(:city) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :city) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :location, "Mekan", class: "event-form-label" %>
      <%= form.text_field :location,
            class: event_form_control_classes(model, :location),
            placeholder: "Salon, kampüs, semt veya çevrim içi bağlantı",
            aria: event_form_aria(model, :location),
            data: { event_preview_target: "location", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :location) %>
        <p id="<%= event_form_field_error_id(:location) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :location) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :capacity, "Kontenjan", class: "event-form-label" %>
      <%= form.number_field :capacity,
            min: 1,
            step: 1,
            class: event_form_control_classes(model, :capacity),
            placeholder: "120",
            aria: event_form_aria(model, :capacity, describedby: "event-capacity-hint"),
            data: { event_preview_target: "capacity" } %>
      <p id="event-capacity-hint" class="event-form-hint">Boş bırakırsan etkinlik sayfasında kontenjan gösterilmez.</p>
      <% if event_form_field_error?(model, :capacity) %>
        <p id="<%= event_form_field_error_id(:capacity) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :capacity) %></p>
      <% end %>
    </div>

    <div class="event-form-note is-blue">
      <%= render "icons/location", class: "size-5" %>
      <p>Şehri ayrı seç; mekan alanına salon, kampüs, semt veya online buluşma bağlantısını yaz.</p>
    </div>
  </div>
</section>

<section class="event-form-step" data-wizard-target="step">
  <div class="event-form-step-intro">
    <p class="section-eyebrow text-coral">Hikaye ve kayıt</p>
    <h3>İnsanlara neden katılmak isteyeceklerini göster.</h3>
    <p>Etkinliğin atmosferini, akışını ve katılımcıların neler bekleyebileceğini anlat.</p>
  </div>

  <div class="event-form-grid">
    <div class="event-form-field md:col-span-2">
      <%= form.label :description, "Açıklama", class: "event-form-label" %>
      <%= form.text_area :description,
            rows: 8,
            class: event_form_control_classes(model, :description, base: "event-form-control event-form-textarea"),
            placeholder: "Atmosferi, akışı ve katılımcıların neler bekleyebileceğini anlat.",
            aria: event_form_aria(model, :description),
            data: { event_preview_target: "description", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :description) %>
        <p id="<%= event_form_field_error_id(:description) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :description) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :price, "Ücret", class: "event-form-label" %>
      <%= form.number_field :price,
            step: "0.01",
            min: 0,
            class: event_form_control_classes(model, :price),
            placeholder: "0",
            aria: event_form_aria(model, :price, describedby: "event-price-hint"),
            data: { event_preview_target: "price" } %>
      <p id="event-price-hint" class="event-form-hint">Ücretsiz etkinlik için 0 yaz veya boş bırak.</p>
      <% if event_form_field_error?(model, :price) %>
        <p id="<%= event_form_field_error_id(:price) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :price) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :ticket_url, "Bilet / kayıt bağlantısı", class: "event-form-label" %>
      <%= form.url_field :ticket_url,
            class: event_form_control_classes(model, :ticket_url),
            placeholder: "https://...",
            aria: event_form_aria(model, :ticket_url, describedby: "event-ticket-url-hint"),
            data: { event_preview_target: "ticketUrl" } %>
      <p id="event-ticket-url-hint" class="event-form-hint">Varsa ana aksiyon bu bağlantıya yönlendirilir.</p>
      <% if event_form_field_error?(model, :ticket_url) %>
        <p id="<%= event_form_field_error_id(:ticket_url) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :ticket_url) %></p>
      <% end %>
    </div>
  </div>
</section>

<section class="event-form-step" data-wizard-target="step">
  <div class="event-form-step-intro">
    <p class="section-eyebrow text-coral">Afiş ve son kontrol</p>
    <h3>Etkinliğinin görsel etkisini güçlendir.</h3>
    <p>İyi bir afiş, keşif akışında etkinliğinin daha hızlı fark edilmesine yardımcı olur. Afişin yok ise merak etme, senin için her kategoriye özel; güzel bir gradyan hazırladık!</p>
  </div>

  <div class="event-form-grid">
    <div class="event-form-field md:col-span-2">
      <%= form.label :image, "Afiş görseli", class: "event-form-label" %>
      <div class="event-form-upload <%= "is-invalid" if event_form_field_error?(model, :image) %>">
        <%= form.file_field :image,
              accept: "image/png,image/jpeg,image/jpg,image/webp",
              class: event_form_control_classes(model, :image, base: "event-form-file"),
              aria: event_form_aria(model, :image, describedby: "event-image-hint"),
              data: { event_preview_target: "imageInput", existing: (model.image.attached? && model.image.attachment&.persisted?) ? "true" : "false" } %>
        <p id="event-image-hint">PNG, JPG veya WebP, en fazla 5 MB.</p>
      </div>
      <% if event_form_field_error?(model, :image) %>
        <p id="<%= event_form_field_error_id(:image) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :image) %></p>
      <% end %>
      <% if model.persisted? && model.image.attached? && model.image.attachment&.persisted? %>
        <label class="event-form-remove-image">
          <%= form.check_box :remove_image, { class: "event-form-remove-image-checkbox" }, "1", "0" %>
          <span>
            <strong>Mevcut afişi kaldır</strong>
            <small>Yeni görsel seçmezsen kaydettiğinde mevcut afiş silinir.</small>
          </span>
        </label>
      <% end %>
    </div>

    <div class="event-form-review md:col-span-2">
      <p class="section-eyebrow text-citron">Yayın akışı</p>
      <div>
        <span>1</span>
        <strong>Hazırlık</strong>
        <p>Formdaki bilgiler etkinlik sayfasının temelini oluşturur.</p>
      </div>
      <div>
        <span>2</span>
        <strong>İnceleme</strong>
        <p>Gönderdiğinde etkinlik otomatik olarak inceleme kuyruğuna alınır.</p>
      </div>
      <div>
        <span>3</span>
        <strong>Yayında</strong>
        <p>Onaylandıktan sonra keşif akışında ve paylaşım sayfasında görünür olur.</p>
      </div>
    </div>
  </div>
</section>
