<section class="event-form-step" data-wizard-target="step">
  <div class="event-form-step-intro">
    <p class="section-eyebrow text-coral">Temel bilgiler</p>
    <h3>Güçlü bir başlangıç yap.</h3>
    <p>Kısa ve net bir başlık, doğru kategoriyle birleştiğinde etkinliğin daha kolay fark edilir..</p>
  </div>

  <div class="event-form-grid">
    <div class="event-form-field md:col-span-2">
      <%= form.label :title, "Etkinlik adı", class: "event-form-label" %>
      <%= form.text_field :title,
            class: event_form_control_classes(model, :title),
            placeholder: "Gece yarısı çatı konseri",
            aria: event_form_aria(model, :title, describedby: "event-title-hint"),
            data: { event_preview_target: "title", wizard_required: "true" } %>
      <p id="event-title-hint" class="event-form-hint">Başlık, etkinliğinin ilk dikkat çeken alanıdır; sade ve güçlü olsun.</p>
      <% if event_form_field_error?(model, :title) %>
        <p id="<%= event_form_field_error_id(:title) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :title) %></p>
      <% end %>
    </div>

    <div class="event-form-field">
      <%= form.label :category, "Kategori", class: "event-form-label" %>
      <%= form.select :category,
            Event.categories.keys.map { |category| [event_category_title(category), category] },
            {},
            class: event_form_control_classes(model, :category),
            aria: event_form_aria(model, :category),
            data: { event_preview_target: "category", wizard_required: "true" } %>
      <% if event_form_field_error?(model, :category) %>
        <p id="<%= event_form_field_error_id(:category) %>" class="event-form-field-error"><%= event_form_field_error_message(model, :category) %></p>
      <% end %>
    </div>

    <div class="event-form-note">
      <%= render "icons/info", class: "size-5" %>
      <p>Kategori, etkinliğinin doğru kitleye ulaşmasına yardımcı olur.</p>
    </div>
  </div>
</section>
