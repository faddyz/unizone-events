<%
  mode = local_assigns.fetch(:mode, :new).to_sym
  presenter = EventFormPresenter.new(
    model: model,
    mode: mode,
    submit_label: submit_label,
    cancel_path: local_assigns[:cancel_path],
    form_title: local_assigns[:form_title],
    form_description: local_assigns[:form_description],
    helpers: self
  )
%>

<%= form_with model: model,
      url: url,
      class: "event-form-studio",
      data: {
        controller: "wizard event-preview",
        action: "input->event-preview#refresh change->event-preview#refresh input->wizard#refresh change->wizard#refresh"
      } do |form| %>
  <%= render "events/form/errors", model: model %>

  <div class="event-form-layout">
    <%= render "events/form/step_rail", presenter: presenter %>
    <%= render "events/form/workspace", form: form, presenter: presenter %>
    <%= render "events/form/preview", presenter: presenter %>
  </div>
<% end %>
