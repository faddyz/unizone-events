<%= form_with model: model, url: url, class: "space-y-6", data: { controller: "wizard" } do |form| %>
  <% if model.errors.any? %>
    <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-800">
      <%= model.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="space-y-3">
    <div class="h-1.5 overflow-hidden rounded-full bg-stone-100">
      <div class="wizard-progress-line h-full rounded-full transition-all duration-300" data-wizard-target="progress"></div>
    </div>
    <div class="grid gap-2 text-xs font-black uppercase tracking-[0.12em] sm:grid-cols-4">
      <% ["Bilgiler", "Zaman/Yer", "Görsel", "Önizleme"].each_with_index do |label, index| %>
        <button type="button" class="rounded-full bg-white px-3 py-2 text-stone-600 transition focus-ring" data-wizard-target="tab" data-wizard-index="<%= index %>" data-action="wizard#go">
          <%= label %>
        </button>
      <% end %>
    </div>
  </div>

  <%= render "events/form_fields", form: form, model: model %>

  <div class="flex flex-wrap items-center gap-3 border-t border-stone-100 pt-6">
    <button type="button" class="btn-outline focus-ring" data-wizard-target="previous" data-action="wizard#previous">Geri</button>
    <button type="button" class="btn-void focus-ring" data-wizard-target="next" data-action="wizard#next">Devam</button>
    <%= form.submit submit_label, class: "btn-electric cursor-pointer border-0 focus-ring", data: { wizard_target: "submit" } %>
    <% if local_assigns[:cancel_path] %>
      <%= link_to "Vazgeç", cancel_path, class: "btn-outline focus-ring" %>
    <% end %>
  </div>
<% end %>
