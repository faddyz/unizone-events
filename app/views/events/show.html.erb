<% content_for :title, @event.title %>
<% content_for :transparent_nav, true %>

<%
  organizer_name = @event.user.name.presence || @event.user.email
  going_count = @event.attendees_count
  interested_count = @event.interested_attendees_count
  not_going_count = @event.not_going_attendees_count
  total_responses = @event.total_responses_count
  capacity = @event.capacity.to_i.positive? ? @event.capacity.to_i : nil
  capacity_percent = capacity ? [[((going_count.to_f / capacity) * 100).round, 100].min, 0].max : nil
  spots_left = capacity ? [capacity - going_count, 0].max : nil
  ticket_url = @event.ticket_url.presence
  attendee_preview = @attendee_preview.to_a
  selected_status = @attendance&.status
  share_text = "#{@event.title} etkinliğine göz at."
  show_controllers = [ "attendance", "share" ]
  show_controllers << "poster-lightbox" if @event.image.attached?
  rsvp_options = [
    { status: "going", label: "Katıl!", active_label: "Yerini aldın!", note: "Katılımını netleştir ve etkinlikteki yerini ayır." },
    { status: "interested", label: "İlgilendiğini göster!", active_label: "İlgileniyorsun!", note: "Henüz kesin değilse etkinliği radarında tut." },
    { status: "not_going", label: "Pas geç.", active_label: "Pas geçildi.", note: "Sana uygun değilse seçimini temiz tut." }
  ]
%>

<div class="event-show-page"
     data-controller="<%= show_controllers.join(" ") %>"
     data-attendance-url-value="<%= event_attendance_path(@event) %>"
     data-attendance-signed-in-value="<%= current_user.present? %>"
     data-attendance-capacity-value="<%= capacity || 0 %>"
     data-attendance-current-status-value="<%= selected_status %>"
     data-share-title-value="<%= @event.title %>"
     data-share-text-value="<%= share_text %>"
     data-share-url-value="<%= request.original_url %>">
  <section class="event-show-hero relative isolate overflow-hidden bg-void text-white">
    <div class="absolute inset-0 <%= event_poster_background_classes(@event) %> opacity-80"></div>
    <div class="poster-noise absolute inset-0"></div>
    <div class="hero-atmosphere absolute inset-0 opacity-70"></div>
    <div class="hero-stage-wash absolute inset-0 opacity-65"></div>
    <div class="hero-ribbon hero-ribbon-citron"></div>
    <div class="hero-ribbon hero-ribbon-blue"></div>
    <div class="soft-grid absolute inset-0 opacity-45"></div>
    <div class="hero-noise absolute inset-0"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-void via-stone-950/70 to-stone-950/28"></div>

    <div class="page-shell relative z-10 grid min-h-[46rem] content-end gap-10 pb-24 pt-32 lg:min-h-[50rem] lg:grid-cols-[minmax(0,1fr)_25rem] lg:items-end lg:pb-28">
      <div class="hero-copy max-w-5xl">
        <%= link_to explore_events_path, class: "mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.07] px-3 py-2 text-xs font-black uppercase tracking-[0.12em] text-white/72 backdrop-blur-xl transition hover:border-citron/60 hover:text-citron focus-ring" do %>
          <%= render "icons/arrow_left", class: "size-4" %>
          Keşfe dön
        <% end %>

        <div class="flex flex-wrap items-center gap-2">
          <span class="<%= event_category_badge_classes(@event) %>"><%= event_category_title(@event) %></span>
          <% unless @event.published? %>
            <span class="<%= event_status_badge_classes(@event) %>"><%= event_status_label(@event) %></span>
          <% end %>
          <span class="rounded-full border border-white/12 bg-white/[0.08] px-3 py-1 font-mono text-[0.65rem] font-black uppercase tracking-[0.12em] text-white/70"><%= @event.date.strftime("%H:%M") %></span>
        </div>

        <h1 class="event-show-title mt-5 max-w-5xl text-pretty font-display text-5xl font-extrabold leading-[0.9] tracking-tight sm:text-7xl lg:text-[84px]">
          <%= @event.title %>
        </h1>
        <p class="mt-6 max-w-3xl text-base font-medium leading-7 text-white/74 sm:text-xl sm:leading-8">
          <%= truncate(@event.description.to_s.squish, length: 190) %>
        </p>

        <div class="event-hero-actions mt-7 flex flex-col gap-4 sm:flex-row sm:items-center">
          <% if ticket_url %>
            <%= link_to ticket_url, target: "_blank", rel: "noopener", class: "event-cta-primary focus-ring" do %>
              <span>Kayıt / Bilet Al</span>
              <%= render "icons/ticket", class: "size-5" %>
            <% end %>
          <% elsif current_user.blank? %>
            <%= link_to new_user_session_path, class: "event-cta-primary focus-ring" do %>
              <span>Giriş yap</span>
              <%= render "icons/check_circle", class: "size-5" %>
            <% end %>
          <% else %>
            <% selected = selected_status == "going" %>
            <button type="button"
                    class="event-cta-primary <%= selected ? "is-active" : "" %> focus-ring"
                    data-attendance-status="going"
                    data-attendance-target="button"
                    data-attendance-active-class="is-active"
                    data-attendance-inactive-class=""
                    data-attendance-default-label="Katıl!"
                    data-attendance-selected-label="Yerini aldın!"
                    data-action="click->attendance#update"
                    aria-pressed="<%= selected %>">
              <span data-attendance-state><%= selected ? "Yerini aldın!" : "Katıl!" %></span>
              <%= render "icons/check_circle", class: "size-5" %>
            </button>
          <% end %>

          <button type="button"
                  class="event-cta-ghost focus-ring"
                  data-share-target="trigger"
                  data-action="share#share"
                  aria-haspopup="dialog"
                  aria-expanded="false"
                  aria-controls="event-share-panel">
            <%= render "icons/link", class: "size-5" %>
            <span data-share-target="label">Paylaş</span>
          </button>
        </div>

        <div class="mt-7 flex flex-wrap items-center gap-3 text-sm font-semibold text-white/66">
          <div class="event-show-avatar-stack" aria-hidden="true">
            <% if attendee_preview.any? %>
              <% attendee_preview.each_with_index do |user, avatar_index| %>
                <% avatar_name = user.name.presence || user.email %>
                <span class="event-show-avatar" style="--avatar-hue: <%= (avatar_name.to_s.sum + avatar_index * 37) % 360 %>"><%= avatar_name.to_s.first.upcase %></span>
              <% end %>
            <% else %>
              <span class="event-show-live-dot"></span>
            <% end %>
          </div>
          <p>
            <strong class="text-white" data-attendance-target="count" data-attendance-count-key="attendees_count"><%= going_count %></strong>
            kişi katılıyor!
            <% if capacity %>
              <span class="text-white/38">/</span>
              <span data-attendance-target="spots"><%= spots_left %></span> yer kaldı
            <% elsif total_responses.positive? %>
              <span class="text-white/38">/</span> <%= total_responses %> toplam geri bildirim.
            <% end %>
          </p>
        </div>
      </div>

      <aside class="event-show-poster-card hidden lg:block" <%= tag.attributes(data: { controller: "poster-palette" }) if @event.image.attached? %>>
        <div class="event-show-date-ticket">
          <span><%= @event.date.strftime("%b") %></span>
          <strong><%= @event.date.strftime("%-d") %></strong>
        </div>
        <% if @event.image.attached? %>
          <button type="button"
                  class="event-show-poster-frame event-show-poster-button <%= event_poster_background_classes(@event) %> focus-ring"
                  data-action="poster-lightbox#open"
                  aria-haspopup="dialog"
                  aria-controls="event-poster-lightbox"
                  aria-label="<%= @event.title %> afişini büyüt">
            <div class="poster-art absolute inset-0 opacity-35"></div>
            <%= image_tag @event.image, alt: @event.title, class: "relative z-10 h-full w-full object-contain p-3 drop-shadow-2xl", data: { poster_palette_target: "image" } %>
            <span class="event-show-poster-zoom">
              <%= render "icons/image", class: "size-4" %>
              <span>Afişi büyüt</span>
            </span>
            <div class="poster-chrome absolute inset-0"></div>
            <div class="poster-spotlight absolute inset-0"></div>
          </button>
        <% else %>
          <div class="event-show-poster-frame <%= event_poster_background_classes(@event) %>">
            <div class="poster-art absolute inset-0 opacity-100"></div>
            <div class="relative z-10 grid h-full place-items-center p-8 text-center">
              <p class="font-display text-4xl font-extrabold leading-none"><%= @event.title %></p>
            </div>
            <div class="poster-chrome absolute inset-0"></div>
            <div class="poster-spotlight absolute inset-0"></div>
          </div>
        <% end %>
        
      </aside>
    </div>
  </section>

  <section class="page-shell relative z-20 -mt-12">
    <dl class="event-essentials-grid">
      <div class="event-essential-card animate-rise-in" style="animation-delay: 40ms">
        <dt>Ne zaman</dt>
        <dd><%= l(@event.date, format: :long) %></dd>
      </div>
      <div class="event-essential-card animate-rise-in" style="animation-delay: 100ms">
        <dt>Mekan / Şehir</dt>
        <dd><%= event_place_text(@event) %></dd>
      </div>
      <div class="event-essential-card animate-rise-in" style="animation-delay: 160ms">
        <dt>Ücret</dt>
        <dd><%= event_price_text(@event) %></dd>
      </div>
      <div class="event-essential-card animate-rise-in" style="animation-delay: 220ms">
        <dt><%= capacity ? "Kontenjan" : "Ev sahibi / Organizatör" %></dt>
        <dd><%= capacity ? "#{going_count}/#{capacity} dolu" : organizer_name %></dd>
      </div>
    </dl>
  </section>

  <section class="page-shell mt-12 grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-start">
    <article class="event-main-content space-y-8">
      <section class="event-section-head">
        <p class="section-eyebrow text-coral">Neden bu plan?</p>
        <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950 lg:text-5xl">Karar vermen için kısa sinyaller.</h2>
      </section>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="event-signal-card is-citron">
          <p class="section-eyebrow">Mod</p>
          <h3><%= event_category_title(@event) %></h3>
          <p><%= event_category_signal_copy(@event) %></p>
        </div>
        <div class="event-signal-card is-blue">
          <p class="section-eyebrow">Kalabalık</p>
          <h3><span data-attendance-target="count" data-attendance-count-key="attendees_count"><%= going_count %></span> kişi katılıyor!</h3>
          <p><%= going_count.positive? ? "Bu etkinlik şimdiden ilgi görmeye başladı." : "İlk katılanlardan biri olup akışı başlat." %></p>
        </div>
        <div class="event-signal-card is-coral">
          <p class="section-eyebrow">Ücret</p>
          <h3><%= event_price_text(@event) %></h3>
          <p><%= @event.free? ? "Bariyer yok; karar vermesi kolay." : "Katılım ücreti net olarak belirtilmiş." %></p>
        </div>
        <div class="event-signal-card is-mint">
          <p class="section-eyebrow"><%= capacity ? "Doluluk" : "Kayıt" %></p>
          <h3><%= capacity ? "%#{capacity_percent}" : (ticket_url ? "Biletli Etkinlik" : "Katılımını belirt!") %></h3>
          <% if capacity %>
            <div class="event-capacity-track mt-4">
              <div class="event-capacity-fill" style="width: <%= capacity_percent %>%" data-attendance-target="meter"></div>
            </div>
            <p class="mt-3"><span data-attendance-target="spots"><%= spots_left %></span> yer kaldı; kontenjan dolmadan kararını netleştir.</p>
          <% else %>
            <p><%= ticket_url ? "Kayıt dış platformda tamamlanıyor; bağlantı seni doğrudan bilet akışına götürür." : "Katılımını buradan bildirebilir, fikrin değişirse seçimini dilediğin an güncelleyebilirsin." %></p>
          <% end %>
        </div>
      </div>
    </article>

    <article class="event-detail-content space-y-8">
      <section class="event-story-card">
        <div class="event-story-orb"></div>
        <p class="section-eyebrow text-coral">Hikaye</p>
        <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950 lg:text-5xl">Oraya gittiğinde ne hissedeceksin?</h2>
        <p class="mt-6 whitespace-pre-line text-lg font-medium leading-8 text-stone-700"><%= @event.description %></p>
      </section>

      <section class="event-practical-card">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="section-eyebrow text-coral">Pratik bilgiler</p>
            <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Planı netleştir.</h2>
          </div>
          <% if ticket_url %>
            <%= link_to ticket_url, target: "_blank", rel: "noopener", class: "section-cta focus-ring" do %>
              <span>Kayıt bağlantısı</span>
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
          <% end %>
        </div>

        <dl class="mt-6 grid gap-4 sm:grid-cols-2">
          <div>
            <dt><%= render "icons/calendar", class: "size-4" %> Tarih</dt>
            <dd><%= l(@event.date, format: :long) %></dd>
          </div>
          <div>
            <dt><%= render "icons/location", class: "size-4" %> Mekan / Şehir</dt>
            <dd><%= event_place_text(@event) %></dd>
          </div>
          <div>
            <dt><%= render "icons/ticket", class: "size-4" %> Ücret</dt>
            <dd><%= event_price_text(@event) %></dd>
          </div>
          <div>
            <dt><%= render "icons/users", class: "size-4" %> Ev sahibi / Organizatör</dt>
            <dd><%= organizer_name %></dd>
          </div>
        </dl>
      </section>

      <% if @similar_events.any? || @organizer_other_events.any? %>
        <div class="event-discovery-divider" aria-hidden="true">
          <span></span>
          <i></i>
          <span></span>
        </div>
      <% end %>

      <% if @similar_events.any? %>
        <section class="event-compact-section space-y-4">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="section-eyebrow text-coral">Benzer akışlar</p>
              <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Bu moda yakın etkinlikler</h2>
              <p class="mt-2 max-w-xl text-sm font-semibold leading-6 text-stone-500">Aynı enerjiye yakın birkaç kısa öneri.</p>
            </div>
            <%= link_to explore_events_path(category: @event.category), class: "section-cta focus-ring" do %>
              <span>Kategoriyi aç</span>
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
          </div>

          <div class="event-compact-grid">
            <% @similar_events.each_with_index do |event, index| %>
              <%= render "events/event_card", event: event, compact: true, index: index %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if @organizer_other_events.any? %>
        <section class="event-compact-section space-y-4">
          <div>
            <p class="section-eyebrow text-emerald-700">Organizatörden</p>
            <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Aynı ekibin diğer etkinlikleri</h2>
          </div>
          <div class="event-compact-grid">
            <% @organizer_other_events.each_with_index do |event, index| %>
              <%= render "events/event_card", event: event, compact: true, index: index %>
            <% end %>
          </div>
        </section>
      <% end %>
    </article>

    <aside class="event-rsvp-aside space-y-4 lg:sticky lg:top-28">
      <section class="event-action-card">
        <p class="section-eyebrow text-coral">Aksiyon</p>
        <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Bu etkinlikte var mısın?</h2>
        <p class="mt-2 text-sm font-semibold leading-6 text-stone-500"><%= current_user.present? ? "Katılacağını netleştir, ilgini göster ya da sana uygun değilse pas geç." : "Katılımını bildirmek ve etkinliği hesabında takip etmek için giriş yap." %></p>

        <% unless current_user.present? %>
          <div class="event-rsvp-auth-card">
            <strong>Katılmak için giriş yap</strong>
            <p>Giriş yaptıktan sonra katılım durumunu seçebilir ve daha sonra dilediğin an değiştirebilirsin.</p>
            <div>
              <%= link_to "Giriş yap", new_user_session_path, class: "event-rsvp-auth-primary focus-ring" %>
              <%= link_to "Hesap oluştur", new_user_registration_path, class: "event-rsvp-auth-secondary focus-ring" %>
            </div>
          </div>
        <% end %>

        <% if ticket_url %>
          <%= link_to ticket_url, target: "_blank", rel: "noopener", class: "event-side-ticket focus-ring" do %>
            <span>Kayıt / Bilet Al</span>
            <%= render "icons/ticket", class: "size-5" %>
          <% end %>
        <% end %>

        <% if current_user.present? %>
          <div class="mt-5 grid gap-2">
            <% rsvp_options.each do |option| %>
              <% selected = selected_status == option[:status] %>
              <button type="button"
                      class="event-rsvp-choice <%= selected ? "is-active" : "" %> focus-ring"
                      data-attendance-status="<%= option[:status] %>"
                      data-attendance-target="button"
                      data-attendance-active-class="is-active"
                      data-attendance-inactive-class=""
                      data-attendance-default-label="<%= option[:label] %>"
                      data-attendance-selected-label="<%= option[:active_label] %>"
                      data-action="click->attendance#update"
                      aria-pressed="<%= selected %>">
                <span>
                  <strong data-attendance-state><%= selected ? option[:active_label] : option[:label] %></strong>
                  <small><%= option[:note] %></small>
                </span>
                <span class="event-rsvp-choice-dot"></span>
              </button>
            <% end %>
          </div>
        <% end %>

        <div class="mt-5 grid grid-cols-3 gap-2 text-center">
          <div class="event-rsvp-stat">
            <strong data-attendance-target="count" data-attendance-count-key="attendees_count"><%= going_count %></strong>
            <span>Katılıyor</span>
          </div>
          <div class="event-rsvp-stat">
            <strong data-attendance-target="count" data-attendance-count-key="interested_attendees_count"><%= interested_count %></strong>
            <span>İlgileniyor</span>
          </div>
          <div class="event-rsvp-stat">
            <strong data-attendance-target="count" data-attendance-count-key="not_going_attendees_count"><%= not_going_count %></strong>
            <span>Pas Geçti</span>
          </div>
        </div>

        <% if capacity %>
          <div class="mt-5 rounded-2xl bg-stone-950 p-4 text-white">
            <div class="flex items-center justify-between gap-3 text-sm font-bold">
              <span>Doluluk</span>
              <span><span data-attendance-target="spots"><%= spots_left %></span> yer kaldı</span>
            </div>
            <div class="event-capacity-track mt-3 bg-white/12">
              <div class="event-capacity-fill" style="width: <%= capacity_percent %>%" data-attendance-target="meter"></div>
            </div>
          </div>
        <% end %>

        <button type="button"
                class="event-share-button focus-ring"
                data-share-target="trigger"
                data-action="share#share"
                aria-haspopup="dialog"
                aria-expanded="false"
                aria-controls="event-share-panel">
          <%= render "icons/link", class: "size-4" %>
          <span data-share-target="label">Paylaş</span>
        </button>
        <div class="event-share-toast hidden" role="status" aria-live="polite" data-share-target="toast"></div>
        <div data-attendance-target="toast" class="hidden" role="status" aria-live="polite"></div>
      </section>

      <% if policy(@event).edit? %>
        <section class="cinema-panel rounded-[1.25rem] p-5">
          <h2 class="font-display text-xl font-extrabold tracking-tight text-stone-950">Yönet</h2>
          <p class="mt-2 text-sm font-medium leading-6 text-stone-600"><%= event_lifecycle_hint(@event) %></p>
          <div class="mt-4 flex flex-col gap-2">
            <% if current_user == @event.user %>
              <%= link_to "Etkinliklerimde aç", organizer_event_path(@event), class: "btn-void flex w-full focus-ring" %>
            <% end %>
            <% if current_user&.admin? %>
              <%= link_to "İncelemede aç", admin_event_path(@event), class: "btn-outline flex w-full focus-ring" %>
            <% end %>
          </div>
        </section>
      <% end %>
    </aside>
  </section>

  <%= render "shared/share_panel", dom_id: "event-share-panel" %>

  <% if @event.image.attached? %>
    <dialog class="event-poster-lightbox"
            id="event-poster-lightbox"
            aria-labelledby="event-poster-lightbox-title"
            data-poster-lightbox-target="dialog"
            data-action="click->poster-lightbox#closeFromBackdrop">
      <div class="event-poster-lightbox-panel">
        <header class="event-poster-lightbox-head">
          <div>
            <p class="section-eyebrow text-citron">Afiş</p>
            <h2 id="event-poster-lightbox-title"><%= @event.title %></h2>
          </div>
          <button type="button"
                  class="event-poster-lightbox-close focus-ring"
                  data-action="poster-lightbox#close"
                  aria-label="Afişi kapat">
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" d="M6 6l12 12M18 6 6 18"/>
            </svg>
          </button>
        </header>
        <div class="event-poster-lightbox-media <%= event_poster_background_classes(@event) %>" data-controller="poster-palette">
          <div class="poster-art absolute inset-0 opacity-35"></div>
          <%= image_tag @event.image, alt: @event.title, class: "event-poster-lightbox-image", data: { poster_palette_target: "image" } %>
          <div class="poster-noise absolute inset-0"></div>
          <div class="poster-chrome absolute inset-0"></div>
        </div>
      </div>
    </dialog>
  <% end %>

  <div class="event-mobile-actions lg:hidden">
    <% if ticket_url %>
      <%= link_to "Kayıt / bilet", ticket_url, target: "_blank", rel: "noopener", class: "event-mobile-primary focus-ring" %>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% elsif current_user.present? %>
      <% going_selected = selected_status == "going" %>
      <% interested_selected = selected_status == "interested" %>
      <% not_going_selected = selected_status == "not_going" %>
      <button type="button"
              class="event-mobile-primary <%= going_selected ? "is-active" : "" %> focus-ring"
              data-attendance-status="going"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="Katıl!"
              data-attendance-selected-label="Yerini aldın!"
              data-action="click->attendance#update"
              aria-pressed="<%= going_selected %>">
        <span data-attendance-state><%= going_selected ? "Yerini aldın!" : "Katıl!" %></span>
      </button>
      <button type="button"
              class="event-mobile-secondary <%= interested_selected ? "is-active" : "" %> focus-ring"
              data-attendance-status="interested"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="İlgilen!"
              data-attendance-selected-label="İlgileniyorsun!"
              data-attendance-visible-when="none interested"
              data-action="click->attendance#update"
              aria-pressed="<%= interested_selected %>"
              <%= "hidden" if going_selected || not_going_selected %>>
        <span data-attendance-state><%= interested_selected ? "İlgileniyorsun!" : "İlgilen!" %></span>
      </button>
      <button type="button"
              class="event-mobile-secondary <%= not_going_selected ? "is-active" : "" %> focus-ring"
              data-attendance-status="not_going"
              data-attendance-target="button"
              data-attendance-active-class="is-active"
              data-attendance-inactive-class=""
              data-attendance-default-label="Pas geç."
              data-attendance-selected-label="Pas geçildi."
              data-attendance-visible-when="not_going"
              data-action="click->attendance#update"
              aria-pressed="<%= not_going_selected %>"
              <%= "hidden" unless not_going_selected %>>
        <span data-attendance-state><%= not_going_selected ? "Pas geçildi." : "Pas geç." %></span>
      </button>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% else %>
      <%= link_to "Giriş yap", new_user_session_path, class: "event-mobile-primary focus-ring" %>
      <button type="button"
              class="event-mobile-icon focus-ring"
              aria-label="Etkinliği paylaş"
              data-share-target="trigger"
              data-action="share#share"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="event-share-panel">
        <%= render "icons/link", class: "size-5" %>
      </button>
    <% end %>
  </div>
</div>
