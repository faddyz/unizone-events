<% show = @event_show %>
<% content_for :title, show.display_title %>
<% content_for :transparent_nav, true %>
<% content_for :stylesheets, page_stylesheet_tags("pages/home-hero", "components/cards", "components/carousel", "pages/event-show") %>

<% if show.preview_mode %>
  <% content_for :head do %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
<% end %>

<div class="event-show-page"
     data-controller="<%= show.controllers.join(" ") %>"
     data-attendance-url-value="<%= show.attendance_path %>"
     data-attendance-signed-in-value="<%= show.signed_in? %>"
     data-attendance-capacity-value="<%= show.capacity || 0 %>"
     data-attendance-current-status-value="<%= show.selected_status %>"
     data-share-title-value="<%= show.display_title %>"
     data-share-text-value="<%= show.share_text %>"
     data-share-url-value="<%= request.original_url %>">
  <%= render "events/show/hero", show: show %>
  <%= render "events/show/mobile_poster", show: show %>
  <%= render "events/show/essentials", show: show %>

  <section class="page-shell mt-12 grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-start">
    <%= render "events/show/main_content", show: show %>
    <%= render "events/show/detail_content", show: show %>
    <%= render "events/show/rsvp_aside", show: show %>
  </section>

  <%= render "shared/share_panel", dom_id: "event-share-panel" unless show.preview_mode %>
  <%= render "events/show/external_redirect_dialog", show: show %>
  <%= render "events/show/poster_lightbox", show: show %>
  <%= render "events/show/mobile_actions", show: show %>
</div>
