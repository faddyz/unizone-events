<% content_for :title, @event.title %>
<% content_for :transparent_nav, true %>

<section class="relative overflow-hidden bg-void text-white">
  <div class="absolute inset-0 <%= event_poster_background_classes(@event) %> opacity-75"></div>
  <% if @event.image.attached? %>
    <%= image_tag @event.image, alt: @event.title, class: "absolute inset-0 h-full w-full object-cover opacity-50" %>
  <% else %>
    <div class="poster-noise absolute inset-0"></div>
  <% end %>
  <div class="soft-grid absolute inset-0 opacity-50"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-void via-stone-950/72 to-stone-950/20"></div>

  <div class="page-shell relative grid min-h-[36rem] content-end gap-5 pb-14 pt-32">
    <div class="flex flex-wrap items-center gap-2">
      <span class="<%= event_category_badge_classes(@event) %>"><%= event_category_title(@event) %></span>
      <% unless @event.published? %>
        <span class="<%= event_status_badge_classes(@event) %>"><%= event_status_label(@event) %></span>
      <% end %>
    </div>
    <div class="max-w-5xl">
      <h1 class="font-display text-5xl font-extrabold leading-[0.95] tracking-tight sm:text-7xl"><%= @event.title %></h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-white/76"><%= @event.description %></p>
    </div>
  </div>
</section>

<section class="page-shell relative z-10 -mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_370px]">
  <div class="space-y-8">
    <dl class="grid gap-3 sm:grid-cols-2">
      <div class="cinema-panel rounded-[1.25rem] p-5">
        <dt class="section-eyebrow text-stone-400">Ne zaman</dt>
        <dd class="font-display mt-2 text-2xl font-extrabold tracking-tight text-stone-950"><%= l(@event.date, format: :long) %></dd>
      </div>
      <div class="cinema-panel rounded-[1.25rem] p-5">
        <dt class="section-eyebrow text-stone-400">Nerede</dt>
        <dd class="font-display mt-2 text-2xl font-extrabold tracking-tight text-stone-950"><%= @event.location %></dd>
      </div>
      <div class="cinema-panel rounded-[1.25rem] p-5">
        <dt class="section-eyebrow text-stone-400">Ev sahibi</dt>
        <dd class="font-display mt-2 text-2xl font-extrabold tracking-tight text-stone-950"><%= @event.user.name.presence || @event.user.email %></dd>
      </div>
      <div class="cinema-panel rounded-[1.25rem] p-5">
        <dt class="section-eyebrow text-stone-400">Ücret</dt>
        <dd class="font-display mt-2 text-2xl font-extrabold tracking-tight text-stone-950"><%= event_price_text(@event) %></dd>
      </div>
    </dl>

    <section class="cinema-panel rounded-[1.25rem] p-6">
      <p class="section-eyebrow text-coral">Detaylar</p>
      <h2 class="font-display mt-2 text-3xl font-extrabold tracking-tight text-stone-950">Etkinlik akışı</h2>
      <p class="mt-4 whitespace-pre-line leading-8 text-stone-700"><%= @event.description %></p>
    </section>

    <% if @similar_events.any? %>
      <section class="space-y-4">
        <h2 class="font-display text-3xl font-extrabold tracking-tight text-stone-950">Benzer etkinlikler</h2>
        <div class="grid gap-5 md:grid-cols-2">
          <% @similar_events.each_with_index do |event, index| %>
            <%= render "events/event_card", event: event, index: index %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @organizer_other_events.any? %>
      <section class="space-y-4">
        <h2 class="font-display text-3xl font-extrabold tracking-tight text-stone-950">Bu ev sahibinden diğerleri</h2>
        <div class="grid gap-5 md:grid-cols-2">
          <% @organizer_other_events.each_with_index do |event, index| %>
            <%= render "events/event_card", event: event, index: index %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>

  <aside class="space-y-4">
    <section class="cinema-panel sticky top-28 rounded-[1.25rem] p-5"
             data-controller="attendance"
             data-attendance-url-value="<%= event_attendance_path(@event) %>"
             data-attendance-signed-in-value="<%= current_user.present? %>">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="section-eyebrow text-coral">RSVP</p>
          <h2 class="font-display mt-1 text-2xl font-extrabold tracking-tight text-stone-950">Yerini kaydet</h2>
        </div>
        <span class="rounded-full bg-citron px-3 py-1 font-mono text-xs font-black uppercase tracking-[0.12em] text-stone-950"><span data-attendance-target="count"><%= @event.attendees_count %></span> gidiyor</span>
      </div>

      <div class="mt-5 grid grid-cols-3 gap-2 text-center text-sm">
        <div class="rounded-lg bg-emerald-50 px-2 py-3 text-emerald-800">
          <p class="font-display text-2xl font-extrabold"><%= @event.attendees_count %></p>
          <p class="font-bold">Gidiyor</p>
        </div>
        <div class="rounded-lg bg-blue-50 px-2 py-3 text-blue-800">
          <p class="font-display text-2xl font-extrabold"><%= @event.interested_attendees_count %></p>
          <p class="font-bold">İlgili</p>
        </div>
        <div class="rounded-lg bg-stone-100 px-2 py-3 text-stone-700">
          <p class="font-display text-2xl font-extrabold"><%= @event.not_going_attendees_count %></p>
          <p class="font-bold">Gitmiyor</p>
        </div>
      </div>

      <% if @attendee_preview.any? %>
        <div class="mt-5 flex items-center gap-2">
          <div class="flex -space-x-2">
            <% @attendee_preview.each do |user| %>
              <span class="grid size-8 place-items-center rounded-full border-2 border-white bg-stone-950 text-xs font-black text-citron"><%= (user.name.presence || user.email).first.upcase %></span>
            <% end %>
          </div>
          <p class="text-sm font-medium leading-5 text-stone-600">İnsanlar şimdiden plana dahil.</p>
        </div>
      <% end %>

      <% if current_user %>
        <div class="mt-5 space-y-2">
          <% [["going", attendance_status_label("going")], ["interested", attendance_status_label("interested")], ["not_going", attendance_status_label("not_going")]].each do |status, label| %>
            <% selected = @attendance&.status == status %>
            <button type="button"
                    data-attendance-status="<%= status %>"
                    data-attendance-target="button"
                    data-action="click->attendance#update"
                    aria-pressed="<%= selected %>"
                    class="flex h-12 w-full items-center justify-between rounded-xl border px-3 text-left text-sm font-black transition focus-ring <%= selected ? "border-stone-950 bg-stone-950 text-white" : "border-stone-200 bg-white text-stone-800 hover:border-stone-950" %>">
              <span><%= label %></span>
              <span><%= selected ? t("ui.saved") : t("ui.choose") %></span>
            </button>
          <% end %>
          <div data-attendance-target="toast" class="hidden" role="status" aria-live="polite"></div>
        </div>
      <% else %>
        <div class="mt-5 space-y-2">
          <%= link_to "RSVP için giriş yap", new_user_session_path, class: "btn-void flex w-full focus-ring" %>
          <%= link_to "Hesap oluştur", new_user_registration_path, class: "btn-outline flex w-full focus-ring" %>
        </div>
      <% end %>
    </section>

    <% if policy(@event).edit? %>
      <section class="cinema-panel rounded-[1.25rem] p-5">
        <h2 class="font-display text-xl font-extrabold tracking-tight text-stone-950">Yönet</h2>
        <p class="mt-2 text-sm font-medium leading-6 text-stone-600"><%= event_lifecycle_hint(@event) %></p>
        <div class="mt-4 flex flex-col gap-2">
          <% if current_user == @event.user %>
            <%= link_to "Etkinliklerimde aç", organizer_event_path(@event), class: "btn-void flex w-full focus-ring" %>
          <% end %>
          <% if current_user&.admin? %>
            <%= link_to "İncelemede aç", admin_event_path(@event), class: "btn-outline flex w-full focus-ring" %>
          <% end %>
        </div>
      </section>
    <% end %>
  </aside>
</section>
