<% content_for :title, @event.title %>
<% content_for :transparent_nav, true %>
<% content_for :stylesheets, page_stylesheet_tags("pages/home-hero", "components/cards", "components/carousel", "pages/event-show") %>

<%
  preview_mode = @preview_mode
  display_title = event_display_title(@event)
  display_description = event_description_text(@event, preserve_paragraphs: true)
  organizer_name = @event.imported? ? nil : (@event.user.name.presence || @event.user.email)
  source_name = @event.imported? ? "Etkinlik.io" : nil
  going_count = event_attendance_count(@event)
  interested_count = @event.interested_attendees_count
  not_going_count = @event.not_going_attendees_count
  total_responses = @event.total_responses_count
  capacity = @event.capacity.to_i.positive? ? @event.capacity.to_i : nil
  capacity_percent = capacity ? [[((going_count.to_f / capacity) * 100).round, 100].min, 0].max : nil
  spots_left = capacity ? [capacity - going_count, 0].max : nil
  ticket_url = event_external_action_url(@event)
  attendee_preview = @attendee_preview.to_a
  selected_status = preview_mode ? nil : @attendance&.status
  share_text = "#{display_title} etkinliğine göz at."
  show_controllers = []
  show_controllers << "attendance" unless preview_mode
  show_controllers << "share" unless preview_mode
  show_controllers << "poster-lightbox" if event_has_poster?(@event)
  show_controllers << "external-redirect" if ticket_url && !preview_mode
  show_controllers << "event-show-motion"
  preview_back_path = if preview_mode && current_user&.admin?
    admin_event_path(@event)
  elsif preview_mode && current_user == @event.user
    organizer_event_path(@event)
  else
    explore_events_path
  end
  preview_back_label = if preview_mode && current_user&.admin?
    "İncelemeye dön"
  elsif preview_mode
    "Etkinliklerime dön"
  else
    "Keşfe dön"
  end
  public_action_label = if ticket_url
    event_external_action_label(@event)
  elsif current_user.blank?
    "Giriş yap"
  else
    "Katıl!"
  end
  title_length = display_title.length
  title_size_class = if title_length >= 100
    "text-3xl sm:text-4xl lg:text-5xl"
  elsif title_length >= 75
    "text-4xl sm:text-5xl lg:text-6xl"
  else
    "text-5xl sm:text-7xl lg:text-[84px]"
  end
  title_density_class = if title_length >= 100
    "is-very-long-title"
  elsif title_length >= 75
    "is-long-title"
  else
    ""
  end
  rsvp_options = [
    { status: "going", label: "Katıl!", active_label: "Yerini aldın!", note: "Katılımını netleştir ve etkinlikteki yerini ayır." },
    { status: "interested", label: "İlgilendiğini göster!", active_label: "İlgileniyorsun!", note: "Henüz kesin değilse etkinliği radarında tut." },
    { status: "not_going", label: "Pas geç.", active_label: "Pas geçildi.", note: "Sana uygun değilse seçimini temiz tut." }
  ]
  event_show_locals = {
    preview_mode: preview_mode,
    display_title: display_title,
    display_description: display_description,
    organizer_name: organizer_name,
    source_name: source_name,
    going_count: going_count,
    interested_count: interested_count,
    not_going_count: not_going_count,
    total_responses: total_responses,
    capacity: capacity,
    capacity_percent: capacity_percent,
    spots_left: spots_left,
    ticket_url: ticket_url,
    attendee_preview: attendee_preview,
    selected_status: selected_status,
    preview_back_path: preview_back_path,
    preview_back_label: preview_back_label,
    public_action_label: public_action_label,
    title_size_class: title_size_class,
    title_density_class: title_density_class,
    rsvp_options: rsvp_options
  }
%>
<% content_for :title, display_title, flush: true %>

<% if preview_mode %>
  <% content_for :head do %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
<% end %>

<div class="event-show-page"
     data-controller="<%= show_controllers.join(" ") %>"
     data-attendance-url-value="<%= event_attendance_path(@event) %>"
     data-attendance-signed-in-value="<%= current_user.present? %>"
     data-attendance-capacity-value="<%= capacity || 0 %>"
     data-attendance-current-status-value="<%= selected_status %>"
     data-share-title-value="<%= display_title %>"
     data-share-text-value="<%= share_text %>"
     data-share-url-value="<%= request.original_url %>">
  <%= render partial: "events/show_hero", locals: event_show_locals %>
  <%= render partial: "events/show_mobile_poster", locals: event_show_locals %>
  <%= render partial: "events/show_essentials", locals: event_show_locals %>

  <section class="page-shell mt-12 grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-start">
    <%= render partial: "events/show_main_content", locals: event_show_locals %>
    <%= render partial: "events/show_detail_content", locals: event_show_locals %>
    <%= render partial: "events/show_rsvp_aside", locals: event_show_locals %>
  </section>

  <%= render "shared/share_panel", dom_id: "event-share-panel" unless preview_mode %>
  <%= render partial: "events/show_external_redirect_dialog", locals: event_show_locals %>
  <%= render partial: "events/show_poster_lightbox", locals: event_show_locals %>
  <%= render partial: "events/show_mobile_actions", locals: event_show_locals %>
</div>
