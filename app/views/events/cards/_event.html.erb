<section class="grid gap-3 sm:grid-cols-3">
  <div class="cinema-panel rounded-[1.25rem] p-4">
    <p class="section-eyebrow text-stone-400">Gidiyor</p>
    <p class="font-display mt-2 text-4xl font-extrabold tracking-tight text-stone-950"><%= event.attendees_count %></p>
  </div>
  <div class="cinema-panel rounded-[1.25rem] p-4">
    <p class="section-eyebrow text-stone-400">İlgileniyor</p>
    <p class="font-display mt-2 text-4xl font-extrabold tracking-tight text-stone-950"><%= event.interested_attendees_count %></p>
  </div>
  <div class="cinema-panel rounded-[1.25rem] p-4">
    <p class="section-eyebrow text-stone-400">Gitmiyor</p>
    <p class="font-display mt-2 text-4xl font-extrabold tracking-tight text-stone-950"><%= event.not_going_attendees_count %></p>
  </div>
</section>
