<%= form_with url: explore_events_path, method: :get, class: "cinema-panel grid gap-3 rounded-[1.25rem] p-3 lg:grid-cols-[1fr_190px_170px_150px_120px]" do |form| %>
  <%= form.label :query, "Etkinlik ara", class: "sr-only" %>
  <%= form.text_field :query, value: params[:query], class: "electric-field h-11 px-4 text-sm focus:outline-none", placeholder: "Müzik, atölye, mekan veya konu ara" %>

  <%= form.label :category, "Kategori", class: "sr-only" %>
  <%= form.select :category,
        options_for_select([["Tüm kategoriler", ""]] + @categories, Array(params[:category]).first),
        {},
        class: "electric-field h-11 px-3 text-sm focus:outline-none" %>

  <%= form.label :date_filter, "Tarih", class: "sr-only" %>
  <%= form.select :date_filter,
        options_for_select([["Tüm tarihler", "all"], ["Yaklaşan", "upcoming"], ["Bugün", "today"], ["Bu hafta", "this_week"], ["Bu ay", "this_month"]], params[:date_filter].presence || "upcoming"),
        {},
        class: "electric-field h-11 px-3 text-sm focus:outline-none" %>

  <%= form.label :sort_by, "Sıralama", class: "sr-only" %>
  <%= form.select :sort_by,
        options_for_select([["En yakın", "date_asc"], ["En yeni", "newest"], ["Popüler", "popular"]], params[:sort_by].presence || "date_asc"),
        {},
        class: "electric-field h-11 px-3 text-sm focus:outline-none" %>

  <%= form.submit "Filtrele", class: "btn-void h-11 cursor-pointer border-0 px-4 py-0 text-sm focus-ring" %>
<% end %>
