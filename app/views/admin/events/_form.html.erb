<%= form_with model: [:admin, event], class: "admin-edit-form" do |form| %>
  <% if event.errors.any? %>
    <div class="admin-form-error" role="alert">
      <strong>Düzenleme kaydedilemedi</strong>
      <p>Devam etmeden önce işaretli alanları kontrol et.</p>
      <ul>
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render "events/form/fields", form: form, model: event %>

  <div class="admin-edit-grid">
    <div>
      <%= form.label :status, "Durum", class: "mb-2 block section-eyebrow text-stone-500" %>
      <%= form.select :status,
            Event.statuses.keys.map { |status| [event_status_label(Event.new(status: status)), status] },
            {},
            class: event_form_control_classes(event, :status, base: "electric-field w-full px-4 py-3 focus:outline-none"),
            aria: event_form_aria(event, :status) %>
      <% if event_form_field_error?(event, :status) %>
        <p id="<%= event_form_field_error_id(:status) %>" class="event-form-field-error"><%= event_form_field_error_message(event, :status) %></p>
      <% end %>
    </div>

    <div>
      <%= form.label :editor_score, "Editoryal öncelik", class: "mb-2 block section-eyebrow text-stone-500" %>
      <%= form.number_field :editor_score,
            min: 0,
            max: 100,
            step: 1,
            class: event_form_control_classes(event, :editor_score, base: "electric-field w-full px-4 py-3 focus:outline-none"),
            placeholder: "Boş bırak: otomatik skor",
            aria: event_form_aria(event, :editor_score) %>
      <% if event_form_field_error?(event, :editor_score) %>
        <p id="<%= event_form_field_error_id(:editor_score) %>" class="event-form-field-error"><%= event_form_field_error_message(event, :editor_score) %></p>
      <% end %>
    </div>

    <div>
      <%= form.label :review_note, "Etkinlik sahibine not", class: "mb-2 block section-eyebrow text-stone-500" %>
      <%= form.text_area :review_note,
            rows: 4,
            class: event_form_control_classes(event, :review_note, base: "electric-field w-full px-4 py-3 focus:outline-none"),
            placeholder: "Yalnızca etkinliği oluşturan kullanıcı görür.",
            aria: event_form_aria(event, :review_note) %>
      <% if event_form_field_error?(event, :review_note) %>
        <p id="<%= event_form_field_error_id(:review_note) %>" class="event-form-field-error"><%= event_form_field_error_message(event, :review_note) %></p>
      <% end %>
    </div>
  </div>

  <div class="admin-edit-actions">
    <%= link_to "Vazgeç", admin_event_path(event), class: "btn-outline focus-ring" %>
    <%= form.submit "Değişiklikleri kaydet", class: "btn-void cursor-pointer border-0 focus-ring" %>
  </div>
<% end %>
