<%= form_with model: [:admin, event], class: "admin-edit-form" do |form| %>
  <% if event.errors.any? %>
    <div class="admin-form-error">
      <strong>Düzenleme kaydedilemedi</strong>
      <span><%= event.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <%= render "events/form_fields", form: form, model: event %>

  <div class="admin-edit-grid">
    <div>
      <%= form.label :status, "Durum", class: "mb-2 block section-eyebrow text-stone-500" %>
      <%= form.select :status, Event.statuses.keys.map { |status| [event_status_label(Event.new(status: status)), status] }, {}, class: "electric-field w-full px-4 py-3 focus:outline-none" %>
    </div>

    <div>
      <%= form.label :review_note, "Etkinlik sahibine not", class: "mb-2 block section-eyebrow text-stone-500" %>
      <%= form.text_area :review_note, rows: 4, class: "electric-field w-full px-4 py-3 focus:outline-none", placeholder: "Yalnızca etkinliği oluşturan kullanıcı görür." %>
    </div>
  </div>

  <div class="admin-edit-actions">
    <%= link_to "Vazgeç", admin_event_path(event), class: "btn-outline focus-ring" %>
    <%= form.submit "Değişiklikleri kaydet", class: "btn-void cursor-pointer border-0 focus-ring" %>
  </div>
<% end %>
