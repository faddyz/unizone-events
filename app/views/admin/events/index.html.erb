<% content_for :title, "İnceleme" %>

<section class="page-shell space-y-8">
  <% actions = capture do %>
    <div class="flex flex-wrap gap-2">
      <% [["submitted", "İncelemede"], ["published", "Yayında"], ["rejected", "Düzenleme gerekli"], ["cancelled", "İptal"], ["all", "Tümü"]].each do |value, label| %>
        <%= link_to label, admin_events_path(filter: value), class: "inline-flex h-9 items-center rounded-full px-3 text-sm font-black #{(@filter == value || (@filter.blank? && value == "submitted")) ? "bg-stone-950 text-citron" : "border border-stone-200 bg-white text-stone-700"}" %>
      <% end %>
    </div>
  <% end %>
  <%= render "shared/page_header",
        eyebrow: "İnceleme",
        title: "Takvimi temiz, güvenilir ve canlı tut.",
        description: "Net etkinlikleri yayına al, eksik olanları kısa notla geri gönder ve pasif planları keşiften çıkar.",
        actions: actions %>

  <div class="grid gap-4 md:grid-cols-4">
    <% @stats.each do |key, value| %>
      <%= render "shared/stat_card", label: event_status_label(Event.new(status: key.to_s)), value: value %>
    <% end %>
  </div>

  <% if @events.any? %>
    <div class="table-shell overflow-x-auto">
      <table class="min-w-full divide-y divide-stone-200 text-sm">
        <thead class="bg-stone-50 text-left section-eyebrow text-stone-500">
          <tr>
            <th class="px-4 py-3">Etkinlik</th>
            <th class="px-4 py-3">Ev sahibi</th>
            <th class="px-4 py-3">Durum</th>
            <th class="px-4 py-3">Tarih</th>
            <th class="px-4 py-3 text-right">Karar</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @events.each do |event| %>
            <tr class="align-top">
              <td class="px-4 py-4">
                <p class="font-body text-base font-bold text-stone-950"><%= link_to event.title, admin_event_path(event), class: "hover:text-coral focus-ring" %></p>
                <p class="mt-1 max-w-xl text-stone-500"><%= truncate(event.description, length: 100) %></p>
              </td>
              <td class="px-4 py-4 font-semibold text-stone-600"><%= event.user.name.presence || event.user.email %></td>
              <td class="px-4 py-4"><span class="<%= event_status_badge_classes(event) %>"><%= event_status_label(event) %></span></td>
              <td class="px-4 py-4 font-semibold text-stone-600"><%= l(event.date, format: :short) %></td>
              <td class="px-4 py-4">
                <div class="flex justify-end gap-2">
                  <%= link_to "İncele", admin_event_path(event), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                  <% unless event.published? %>
                    <%= button_to "Yayına al", publish_admin_event_path(event), method: :patch, class: "btn-electric min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= paginate @events, theme: "tailwind" %>
  <% else %>
    <%= render "shared/empty_state", title: "İncelenecek etkinlik yok", description: "Kullanıcılar etkinlik gönderdiğinde burada görünecek." %>
  <% end %>
</section>
