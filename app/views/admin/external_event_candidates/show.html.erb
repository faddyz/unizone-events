<% content_for :title, candidate_display_title(@candidate) %>
<% content_for :stylesheets, page_stylesheet_tags("pages/admin-events") %>

<section class="admin-review-page admin-show-page page-shell">
  <%= render "admin/external_event_candidates/show_hero" %>

  <div class="admin-show-layout">
    <article class="admin-show-main">
      <%= render "admin/external_event_candidates/show_poster" %>
      <%= render "admin/external_event_candidates/show_approval_form" %>
    </article>

    <aside class="admin-show-side">
      <%= render "admin/external_event_candidates/show_quality_panel" %>
      <%= render "admin/external_event_candidates/show_raw_data_panel" %>
    </aside>
  </div>
</section>
