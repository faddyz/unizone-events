<% content_for :title, "API Adayları" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/admin-events") %>

<%
  status_labels = {
    "pending" => "Bekleyen",
    "approved" => "Onaylanan",
    "skipped" => "Geçilen",
    "rejected" => "Reddedilen",
    "hidden" => "Gizli",
    "expired" => "Süresi Geçmiş"
  }
  last_scan_parts = if @last_run
    [
      "Son tarama: #{admin_relative_time(@last_run.started_at || @last_run.created_at)}",
      "#{@last_run.fetched_count} aday",
      "#{@last_run.duplicate_count} duplicate",
      "#{@last_run.new_candidate_count} yeni",
      "#{@last_run.hidden_count} gizli",
      "#{@last_run.skipped_count} geçilen",
      "#{@last_run.failed_count} failed"
    ]
  else
    [ "Son tarama yok" ]
  end
%>

<section class="admin-review-page page-shell admin-candidates-page">
  <header class="admin-review-hero admin-compact-hero">
    <div class="admin-review-hero-copy">
      <p class="section-eyebrow">Etkinlik.io aday havuzu</p>
      <h1>API Adayları</h1>
      <p>Etkinlik.io verisini admin inceleme kuyruğunda hızlıca tara, seç, düzenle ve yayına al.</p>
      <div class="admin-review-hero-actions">
        <%= link_to "Etkinlik moderasyonu", admin_events_path, class: "admin-secondary-action focus-ring" %>
      </div>
    </div>

    <aside class="admin-next-review">
      <p class="section-eyebrow">Özet</p>
      <h2><%= @candidates.total_count %> kayıt</h2>
      <p><%= @preset_tabs.to_h.fetch(@preset) %></p>
    </aside>
  </header>

  <section class="admin-candidate-summary" aria-label="Aday havuzu özeti">
    <div class="admin-summary-chip-row">
      <% status_labels.each do |status, label| %>
        <span class="admin-summary-chip is-<%= candidate_summary_tone(status) %>">
          <%= label %> <strong><%= @stats.fetch(status, 0) %></strong>
        </span>
      <% end %>
    </div>
    <div class="admin-last-scan-strip">
      <% last_scan_parts.each do |part| %>
        <span><%= part %></span>
      <% end %>
    </div>
  </section>

  <details class="admin-review-controls admin-scan-controls admin-collapsible">
    <summary class="admin-collapsible-summary focus-ring">
      <span>Tarama ve Temizlik</span>
      <small>Se?ili kapsam? tara, kaydet, temizle</small>
    </summary>
    <div class="admin-collapsible-body">
    <div>
      <div class="admin-section-head">
        <div>
          <p class="section-eyebrow text-coral">Tarama</p>
          <h2>Seçili kapsamı tara</h2>
        </div>
      </div>

      <%= form_with url: scan_admin_external_event_candidates_path,
            method: :post,
            class: "admin-candidate-scan-form",
            local: true,
            data: {
              controller: "scan-scope",
              action: "turbo:submit-start->scan-scope#scanStarted turbo:submit-end->scan-scope#scanEnded"
            } do %>
        <div class="admin-scan-preset-bar">
          <button type="button" class="admin-scan-preset is-primary is-active focus-ring" data-scan-preset="default" data-action="scan-scope#defaultScope">
            Varsayılan kapsam
          </button>
          <button type="button" class="admin-scan-preset focus-ring" data-scan-preset="growth" data-action="scan-scope#growthScope">
            Geniş Potansiyel
          </button>
          <button type="button" class="admin-scan-preset focus-ring" data-scan-preset="all_cities" data-action="scan-scope#allCities">
            Tüm şehirler
          </button>
          <button type="button" class="admin-scan-preset focus-ring" data-scan-preset="clear_cities" data-action="scan-scope#clearCities">
            Şehirleri temizle
          </button>
          <button type="button" class="admin-scan-preset focus-ring" data-scan-preset="clear_taxonomy" data-action="scan-scope#clearTaxonomy">
            Format/kategori temizle
          </button>
        </div>

        <details class="admin-candidate-details admin-scan-picker" open>
          <summary class="focus-ring">
            <span>Şehirler</span>
            <small><%= @scan_city_options.size %> şehir</small>
          </summary>
          <div class="admin-candidate-check-grid is-compact">
            <% @scan_city_options.each do |label, _id, slug| %>
              <% default_selected = EtkinlikIo::Catalog::DEFAULT_CITY_SLUGS.include?(slug.to_s) %>
              <label class="admin-candidate-check">
                <%= check_box_tag "city_slugs[]", slug, default_selected,
                      data: { scan_scope_target: "city", default_selected: default_selected, city_slug: slug } %>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
        </details>

        <div class="admin-candidate-control-grid">
          <label>
            <span>Başlangıç</span>
            <%= date_field_tag :start_date, Time.zone.today, class: "admin-filter-select focus-ring" %>
          </label>
          <label>
            <span>Bitiş</span>
            <%= date_field_tag :end_date, 45.days.from_now.to_date, class: "admin-filter-select focus-ring" %>
          </label>
          <label>
            <span>Venue type</span>
            <%= select_tag :venue_type, options_for_select([["Tümü", ""], ["VENUE", "VENUE"], ["MANUEL", "MANUEL"], ["ONLINE", "ONLINE"]]), class: "admin-filter-select focus-ring" %>
          </label>
          <label>
            <span>Batch</span>
            <%= number_field_tag :batch_size, EtkinlikIo::Scanner::DEFAULT_BATCH_SIZE, min: 1, max: 100, class: "admin-filter-select focus-ring" %>
          </label>
          <label>
            <span>Limit</span>
            <%= number_field_tag :max_scan_limit, EtkinlikIo::Scanner::DEFAULT_MAX_SCAN_LIMIT, min: 1, max: 3000, class: "admin-filter-select focus-ring" %>
          </label>
        </div>

        <details class="admin-candidate-details admin-scan-picker">
          <summary class="focus-ring">
            <span>Format ve kategori</span>
            <small>API kataloğu</small>
          </summary>
          <div class="admin-candidate-pick-grid">
            <div>
              <strong>Format</strong>
              <% @scan_format_options.each do |label, id, slug| %>
                <% default_selected = EtkinlikIo::Catalog::PRIORITY_FORMAT_IDS.include?(id.to_i) %>
                <label class="admin-candidate-check">
                  <%= check_box_tag "format_ids[]", id, default_selected,
                        data: { scan_scope_target: "format", default_selected: default_selected, format_slug: slug, format_id: id } %>
                  <span><%= label %> <small><%= slug %></small></span>
                </label>
              <% end %>
            </div>
            <div>
              <strong>Kategori</strong>
              <% @scan_category_options.each do |label, id, slug| %>
                <label class="admin-candidate-check">
                  <%= check_box_tag "category_ids[]", id, false,
                        data: { scan_scope_target: "category", default_selected: false, category_slug: slug, category_id: id } %>
                  <span><%= label %> <small><%= slug %></small></span>
                </label>
              <% end %>
            </div>
          </div>
        </details>

        <label class="admin-candidate-check admin-low-priority-check">
          <%= check_box_tag :include_low_priority, "1", false %>
          <span>Düşük öncelik / tiyatro / çocuk kategorilerini dahil et</span>
        </label>

        <div class="admin-event-actions">
          <%= button_tag "Dry-run", type: :submit, name: "dry_run", value: "1", class: "admin-search-submit focus-ring", data: { turbo_confirm: "Dry-run ba?lat?ls?n m?? Kay?t DB'ye yaz?lmaz.", scan_scope_target: "submitButton", scan_action_label: "Dry-run çalışıyor" } %>
          <%= button_tag "Adayları Kaydet", type: :submit, name: "dry_run", value: "0", class: "admin-primary-action focus-ring", data: { turbo_confirm: "Tarama sonuclari aday havuzuna kaydedilecek. Devam edilsin mi?", scan_scope_target: "submitButton", scan_action_label: "Adaylar kaydediliyor" } %>
        </div>
        <div class="admin-scan-progress hidden" role="status" aria-live="polite" data-scan-scope-target="progress">
          <div>
            <strong data-scan-scope-target="progressTitle">Tarama çalışıyor</strong>
            <span data-scan-scope-target="progressStatus">API taranıyor. Sekmeyi açık bırak.</span>
          </div>
          <div class="admin-scan-progress-track" aria-hidden="true">
            <span></span>
          </div>
        </div>
      <% end %>
    </div>

    <div>
      <div class="admin-section-head">
        <div>
          <p class="section-eyebrow text-coral">Temizlik</p>
          <h2>Retansiyon</h2>
        </div>
      </div>
      <p class="admin-muted-copy">Tarihi geçmiş pending/skipped/hidden kayıtlar expired olur. Eski rejected/skipped/hidden ve expired kayıtlar temizlenir; eski approved kayıtların ağır JSON alanları boşaltılır.</p>
      <%= button_to "Cleanup Çalıştır", cleanup_admin_external_event_candidates_path, method: :post, class: "admin-danger-submit focus-ring", data: { turbo_confirm: "Cleanup calisacak: expired/old kayitlar temizlenecek. Devam edilsin mi?" } %>
      <p class="admin-muted-copy">Yanlış preset ile import yaptıysan, yayınlanan veya karar verilmiş (skip/reject) adaylar hariç tüm havuzu silebilirsin.</p>
      <%= button_to "Karar Verilmeyenleri Sil", reset_import_pool_admin_external_event_candidates_path,
            method: :delete,
            class: "admin-danger-submit focus-ring",
            data: { turbo_confirm: "Yayınlanan, skip ve reject dışındaki tüm adaylar silinecek. Devam edilsin mi?" } %>
    </div>
    </div>
  </details>

  <section class="admin-review-controls admin-candidate-filter-controls">
    <div class="admin-filter-tabs" aria-label="Aday presetleri">
      <% @preset_tabs.each do |value, label| %>
        <%= link_to admin_external_event_candidates_path(preset: value, query: @query.presence, per_page: @per_page),
              class: "admin-filter-tab #{value == @preset ? "is-active" : ""} focus-ring",
              aria: (value == @preset ? { current: "page" } : {}) do %>
          <span><%= label %></span>
          <strong><%= value.in?(ExternalEventCandidate.statuses.keys) ? @stats.fetch(value, 0) : "" %></strong>
        <% end %>
      <% end %>
    </div>

    <%= form_with url: admin_external_event_candidates_path, method: :get, class: "admin-search-form", local: true do %>
      <%= hidden_field_tag :preset, @preset %>
      <%= hidden_field_tag :per_page, @per_page %>
      <label class="sr-only" for="admin-candidate-query">Aday ara</label>
      <div class="admin-search-field">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <%= text_field_tag :query, @query, id: "admin-candidate-query", placeholder: "Başlık, mekan, şehir ara", class: "focus-ring" %>
      </div>
      <%= submit_tag "Filtrele", class: "admin-search-submit focus-ring" %>
      <%= select_tag :per_page, options_for_select([["20 / sayfa", 20], ["50 / sayfa", 50], ["100 / sayfa", 100]], @per_page), class: "admin-filter-select focus-ring", onchange: "this.form.requestSubmit()" %>
      <%= link_to "Temizle", admin_external_event_candidates_path(preset: @preset, per_page: @per_page), class: "admin-clear-link focus-ring" if @query.present? %>
    <% end %>
  </section>

  <section class="admin-review-results">
    <%= turbo_frame_tag "admin_candidate_results" do %>
    <div class="admin-section-head">
      <div>
        <p class="section-eyebrow text-coral">Aday listesi</p>
        <h2><%= @candidates.total_count %> kayıt</h2>
      </div>
      <span><%= @preset_tabs.to_h.fetch(@preset) %></span>
    </div>

    <%= form_with url: bulk_admin_external_event_candidates_path, method: :patch, local: true, data: { controller: "candidate-bulk" } do %>
      <%= hidden_field_tag :preset, @preset %>
      <%= hidden_field_tag :query, @query %>
      <%= hidden_field_tag :per_page, @per_page %>
      <%= hidden_field_tag :page, params[:page] %>

      <div class="admin-bulk-global">
        <%= button_tag "Filtredeki Tum Pendingleri Yayina Al", type: :submit, name: "bulk_action", value: "approve_filtered", class: "admin-primary-action focus-ring", data: { turbo_confirm: "Bu filtredeki tum pending adaylar tek seferde yayinlanacak. Devam edilsin mi?" } %>
      </div>

      <% if @candidates.any? || (turbo_frame_request? && flash.any?) %>
      <div class="admin-bulk-toolbar">
        <% if turbo_frame_request? %>
          <% flash.each do |key, value| %>
            <div role="<%= key.to_s == "alert" ? "alert" : "status" %>" class="admin-candidate-flash is-<%= key.to_s == "alert" ? "alert" : "notice" %>">
              <%= value %>
            </div>
          <% end %>
        <% end %>

      <% if @candidates.any? %>
        <div class="admin-select-all-strip">
          <label class="admin-select-all-control">
            <%= check_box_tag :select_all_candidates, "1", false,
                  data: { candidate_bulk_target: "selectAll", action: "candidate-bulk#toggleAll" } %>
            <span>Tümünü seç</span>
          </label>
          <span>Satıra tıklayarak da seçebilirsin.</span>
        </div>
      <% end %>

      <div class="admin-bulk-bar hidden" data-candidate-bulk-target="bar">
        <strong><span data-candidate-bulk-target="count">0</span> aday seçildi</strong>
        <div>
          <%= button_tag "Seçilenleri Yayına Al", type: :submit, name: "bulk_action", value: "approve", class: "admin-primary-action focus-ring", data: { turbo_confirm: "Secili adaylar yayinlanacak. Devam edilsin mi?" } %>
          <%= button_tag "Geç", type: :submit, name: "bulk_action", value: "skip", class: "admin-secondary-action focus-ring" %>
          <%= button_tag "Reddet", type: :submit, name: "bulk_action", value: "reject", class: "admin-danger-submit focus-ring" %>
          <button type="button" class="admin-clear-link focus-ring" data-action="candidate-bulk#clear">Seçimi Temizle</button>
        </div>
      </div>

      </div>
      <% end %>

      <% if @candidates.any? %>
        <div class="admin-candidate-list">
          <% @candidates.each do |candidate| %>
            <article class="admin-candidate-row" data-candidate-bulk-target="row" data-action="click->candidate-bulk#toggleRow">
              <div class="admin-candidate-thumb <%= event_poster_background_classes(candidate.category.presence || "community") %>">
                <label class="admin-candidate-select-wrap" aria-label="<%= candidate_display_title(candidate) %> seç">
                  <%= check_box_tag "candidate_ids[]", candidate.id, false,
                        class: "admin-candidate-select",
                        data: { candidate_bulk_target: "checkbox", action: "click->candidate-bulk#update" } %>
                  <span></span>
                </label>
                <% if candidate.poster_url.present? %>
                  <%= image_tag candidate.poster_url, alt: candidate_display_title(candidate), loading: "lazy" %>
                <% else %>
                  <div class="poster-noise absolute inset-0"></div>
                  <span>Poster yok</span>
                <% end %>
              </div>

              <div class="admin-candidate-row-main">
                <div class="admin-candidate-row-head">
                  <div>
                    <div class="admin-event-tags">
                      <span class="candidate-status candidate-status-<%= candidate.status %>"><%= candidate_status_label(candidate) %></span>
                      <span class="<%= event_category_badge_classes(candidate.category.presence || "community") %>"><%= event_category_title(candidate.category.presence || "community") %></span>
                      <span class="candidate-status"><%= candidate_price_label(candidate) %></span>
                    </div>
                    <h3><%= link_to candidate_display_title(candidate), admin_external_event_candidate_path(candidate), class: "focus-ring", data: { turbo_frame: "_top" } %></h3>
                  </div>

                  <div class="admin-candidate-row-actions">
                    <%= link_to "Önizle", admin_external_event_candidate_path(candidate), class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring", data: { turbo_frame: "_top" } %>
                    <% unless candidate.approved? %>
                      <%= link_to "Yayına Al", approve_admin_external_event_candidate_path(candidate), data: { turbo_method: :patch }, class: "btn-electric min-h-9 px-3 py-1.5 text-xs focus-ring" %>
                    <% end %>
                    <%= link_to "Geç", skip_admin_external_event_candidate_path(candidate), data: { turbo_method: :patch }, class: "btn-outline min-h-9 px-3 py-1.5 text-xs focus-ring" unless candidate.skipped? %>
                    <%= link_to "Reddet", reject_admin_external_event_candidate_path(candidate), data: { turbo_method: :patch }, class: "admin-danger-action focus-ring" unless candidate.rejected? %>
                  </div>
                </div>

                <div class="admin-candidate-meta-line">
                  <span><%= candidate.starts_at ? l(candidate.starts_at, format: :short) : "Tarih eksik" %></span>
                  <span><%= candidate_city_label(candidate) %></span>
                  <span><%= candidate_short_location(candidate) %></span>
                  <span><%= candidate_ticket_kind_label(candidate) %></span>
                </div>

                <p class="admin-event-description"><%= candidate_description_snippet(candidate) %></p>

                <div class="admin-candidate-warning-row">
                  <% candidate_warning_badges(candidate).each do |label, tone| %>
                    <span class="candidate-warning is-<%= tone %>"><%= label %></span>
                  <% end %>
                  <% if candidate_source_action_url(candidate).present? %>
                    <%= link_to candidate_source_action_label(candidate), candidate_source_action_url(candidate), target: "_blank", rel: "noopener", class: "candidate-source-link focus-ring" %>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>

        <div class="admin-pagination" data-turbo-frame="_top">
          <%= paginate @candidates, theme: "tailwind" %>
        </div>
      <% else %>
        <div class="admin-empty-state">
          <span class="admin-live-dot"></span>
          <h3>Bu görünümde aday yok</h3>
          <p>Başka preset seç veya yeni bir dry-run/kayıtlı tarama başlat.</p>
        </div>
      <% end %>
    <% end %>
    <% end %>
  </section>
</section>
