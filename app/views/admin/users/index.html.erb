<% content_for :title, "Kullanici Moderasyonu" %>
<% content_for :stylesheets, page_stylesheet_tags("pages/admin-events") %>

<section class="admin-review-page page-shell admin-users-page">
  <header class="admin-review-hero admin-compact-hero">
    <div class="admin-review-hero-copy">
      <p class="section-eyebrow">Kullanici moderasyonu</p>
      <h1>Rolleri tek ekrandan yonet.</h1>
      <p>Kullanici hesaplarini ara, admin yetkisi ver veya ekipten ayrilan hesaplarin admin rolunu kaldir.</p>
      <div class="admin-review-hero-actions">
        <%= link_to "Etkinlik moderasyonu", admin_events_path, class: "admin-secondary-action focus-ring" %>
        <%= link_to "API Adaylari", admin_external_event_candidates_path, class: "admin-secondary-action focus-ring" %>
      </div>
    </div>

    <aside class="admin-next-review">
      <p class="section-eyebrow">Yetki ozeti</p>
      <h2><%= @stats[:admins] %> admin</h2>
      <p><%= @stats[:total] %> toplam kullanici icinde yetkili hesap sayisi.</p>
    </aside>
  </header>

  <div class="admin-signal-grid">
    <% [
      [ "Toplam", @stats[:total], "Kayitli hesap" ],
      [ "Admin", @stats[:admins], "Panel yetkisi olan" ],
      [ "Uye", @stats[:members], "Standart hesap" ],
      [ "Yeni", @stats[:recent], "Son 7 gun" ]
    ].each_with_index do |(label, value, hint), index| %>
      <article class="admin-signal-card is-tone-<%= index + 1 %>">
        <span class="admin-live-dot"></span>
        <p><%= label %></p>
        <strong><%= value %></strong>
        <small><%= hint %></small>
      </article>
    <% end %>
  </div>

  <section class="admin-review-controls admin-user-controls">
    <div class="admin-filter-tabs" aria-label="Kullanici rol filtreleri">
      <% @role_filters.each do |value, label| %>
        <%= link_to admin_users_path(role: (value == "all" ? nil : value), query: @query.presence),
              class: "admin-filter-tab #{value == @role ? "is-active" : ""} focus-ring",
              aria: (value == @role ? { current: "page" } : {}) do %>
          <span><%= label %></span>
          <strong><%= value == "all" ? @stats[:total] : (value == "admin" ? @stats[:admins] : @stats[:members]) %></strong>
        <% end %>
      <% end %>
    </div>

    <%= form_with url: admin_users_path, method: :get, class: "admin-search-form admin-user-search-form", local: true do %>
      <% unless @role == "all" %>
        <%= hidden_field_tag :role, @role %>
      <% end %>
      <label class="sr-only" for="admin-user-query">Kullanici ara</label>
      <div class="admin-search-field">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <%= text_field_tag :query, @query, id: "admin-user-query", placeholder: "Ad veya e-posta ara", class: "focus-ring" %>
      </div>
      <%= submit_tag "Ara", class: "admin-search-submit focus-ring" %>
      <% if @active_filters %>
        <%= link_to "Temizle", admin_users_path, class: "admin-clear-link focus-ring" %>
      <% end %>
    <% end %>
  </section>

  <section class="admin-review-results">
    <div class="admin-section-head">
      <div>
        <p class="section-eyebrow text-coral">Hesap listesi</p>
        <h2><%= @users.total_count %> kullanici</h2>
      </div>
      <span><%= @role_filters.to_h.fetch(@role) %></span>
    </div>

    <% if @users.any? %>
      <div class="admin-user-list">
        <% @users.each do |user| %>
          <% display_name = user.name.presence || "Isimsiz kullanici" %>
          <article class="admin-user-row">
            <div class="admin-user-avatar" aria-hidden="true"><%= (display_name.presence || user.email).first.upcase %></div>
            <div class="admin-user-main">
              <div class="admin-user-title-line">
                <div>
                  <h3><%= display_name %></h3>
                  <p><%= user.email %></p>
                </div>
                <span class="admin-role-badge <%= user.admin? ? "is-admin" : "is-member" %>"><%= user.admin? ? "Admin" : "Uye" %></span>
              </div>

              <dl class="admin-user-facts">
                <div>
                  <dt>Kayit</dt>
                  <dd><%= l(user.created_at, format: :short) %></dd>
                </div>
                <div>
                  <dt>Etkinlik</dt>
                  <dd><%= user.try(:events_count).to_i %></dd>
                </div>
                <div>
                  <dt>Plan</dt>
                  <dd><%= user.try(:attendances_count).to_i %></dd>
                </div>
              </dl>
            </div>

            <div class="admin-user-actions">
              <% if user.admin? %>
                <%= button_to "Admin rolunu kaldir",
                      admin_user_path(user),
                      method: :patch,
                      params: { user: { admin: false }, role: @role, query: @query },
                      class: "admin-danger-action focus-ring",
                      disabled: user == current_user,
                      data: { turbo_confirm: "#{user.email} icin admin rolu kaldirilsin mi?" } %>
              <% else %>
                <%= button_to "Admin yap",
                      admin_user_path(user),
                      method: :patch,
                      params: { user: { admin: true }, role: @role, query: @query },
                      class: "admin-primary-action focus-ring",
                      data: { turbo_confirm: "#{user.email} admin yapilsin mi?" } %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>

      <div class="admin-pagination">
        <%= paginate @users, theme: "tailwind" %>
      </div>
    <% else %>
      <div class="admin-empty-state">
        <span class="admin-live-dot"></span>
        <h3>Kullanici bulunamadi</h3>
        <p>Aramayi veya rol filtresini temizleyerek listeyi tekrar gorebilirsin.</p>
        <%= link_to "Filtreleri temizle", admin_users_path, class: "btn-void focus-ring" if @active_filters %>
      </div>
    <% end %>
  </section>
</section>
