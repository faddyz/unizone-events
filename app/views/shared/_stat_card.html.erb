<div class="cinema-panel rounded-[1.25rem] p-5">
  <p class="section-eyebrow text-stone-400"><%= label %></p>
  <p class="font-display mt-2 text-4xl font-extrabold tracking-tight text-stone-950"><%= value %></p>
  <% if local_assigns[:hint].present? %>
    <p class="mt-2 text-sm font-medium leading-6 text-stone-600"><%= hint %></p>
  <% end %>
</div>
