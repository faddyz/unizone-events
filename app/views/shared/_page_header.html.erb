<header class="cinema-panel relative overflow-hidden rounded-[1.35rem] p-6 <%= local_assigns[:actions].present? ? "sm:flex sm:items-end sm:justify-between sm:gap-6" : "" %>">
  <div class="absolute right-0 top-0 h-32 w-48 bg-citron/20 blur-3xl pointer-events-none"></div>
  <div class="relative">
    <% if local_assigns[:eyebrow].present? %>
      <p class="section-eyebrow text-coral"><%= eyebrow %></p>
    <% end %>
    <h1 class="font-display mt-2 max-w-4xl text-3xl font-extrabold tracking-tight text-stone-950 sm:text-5xl"><%= title %></h1>
    <% if local_assigns[:description].present? %>
      <p class="mt-3 max-w-3xl text-sm font-medium leading-6 text-stone-600"><%= description %></p>
    <% end %>
  </div>

  <% if local_assigns[:actions].present? %>
    <div class="relative mt-5 flex flex-wrap gap-2 sm:mt-0">
      <%= actions %>
    </div>
  <% end %>
</header>
